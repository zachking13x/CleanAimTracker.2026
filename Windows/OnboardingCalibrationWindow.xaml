<Window x:Class="CleanAimTracker.Windows.OnboardingCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clean Aim Tracker — Calibration"
        Width="780" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource AppBackground}"
        ShowInTaskbar="True">
    <!-- TASK-4.1: opaque window — AllowsTransparency removed and the background
         keys verified against DarkTheme.xaml (the old window referenced
         PanelBackground/HeaderBackground, which don't exist → desktop wallpaper
         bled through behind the body text). -->

    <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource CardBackground}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="18,12">
                    <TextBlock Text="CLEAN AIM TRACKER" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="  ·  CALIBRATION" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource MutedText}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕"
                        Click="Skip_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedText}"
                        BorderThickness="0"
                        FontSize="14"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Cursor="Hand"/>
            </Grid>

            <!-- ═══════════ Content states ═══════════ -->
            <Grid Grid.Row="1" Margin="36,28,36,0">

                <!-- STATE 0: Welcome -->
                <StackPanel x:Name="PageWelcome" Visibility="Visible" MaxWidth="560">
                    <TextBlock Text="Find out exactly what's holding your aim back."
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,16"/>
                    <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,14">
                        Clean Aim Tracker measures your real mouse mechanics and tells you what's wrong and what to fix — directly, with numbers.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22"
                               Foreground="{DynamicResource SecondaryText}">
                        It starts with a 5-minute calibration: four short tests, one per aim skill. When they're done, the coach shows you your baseline, your weakest skill, and the one drill to run first.
                    </TextBlock>
                </StackPanel>

                <!-- STATE 1: Brief -->
                <StackPanel x:Name="PageBrief" Visibility="Collapsed" MaxWidth="560">
                    <TextBlock Text="Four tests. 30 seconds each."
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,8,0,16"/>
                    <StackPanel x:Name="BriefTestList"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12" FontStyle="Italic"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0,14,0,0">
                        Don't warm up, don't try to game it — the coach needs your honest baseline to coach you properly.
                    </TextBlock>
                </StackPanel>

                <!-- STATE 2: Calibration running -->
                <Grid x:Name="PageCalibration" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="TestLabel" Text="Test 1/4"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}"/>
                            <TextBlock x:Name="TestDesc" Text=""
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="TimerText" Text="0:30"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="1" Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1"
                            CornerRadius="8" ClipToBounds="True">
                        <Canvas x:Name="TestCanvas" Background="#070F14"
                                MouseDown="TestCanvas_MouseDown"
                                Cursor="Cross"/>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="HITS " FontSize="11" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LiveHitsText" Text="0" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentGreen}" Margin="0,0,18,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ACCURACY " FontSize="11" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LiveAccText" Text="--" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,18,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LiveReactLabel" Text="PACE " FontSize="11" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LiveReactText" Text="--" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- STATE 3: First Insight -->
                <StackPanel x:Name="PageInsight" Visibility="Collapsed" MaxWidth="560">
                    <TextBlock Text="Your baseline."
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,4,0,14"/>
                    <StackPanel x:Name="InsightScoreList" Margin="0,0,0,12"/>
                    <Border Background="{DynamicResource AccentSubtle}"
                            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                        <TextBlock x:Name="InsightSentence" TextWrapping="Wrap"
                                   FontSize="13" LineHeight="20"
                                   Foreground="{DynamicResource PrimaryText}"/>
                    </Border>
                    <Button x:Name="FreeReportBtn"
                            Content="📋  See my full coaching report (free)"
                            Click="FreeReport_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- STATE 4: First Drill -->
                <StackPanel x:Name="PageFirstDrill" Visibility="Collapsed" MaxWidth="560">
                    <TextBlock Text="Your first drill."
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,8,0,14"/>
                    <TextBlock x:Name="FirstDrillReason" TextWrapping="Wrap"
                               FontSize="14" LineHeight="22"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,16"/>
                    <Border Background="{DynamicResource CardBgGreen}"
                            BorderBrush="{DynamicResource AccentGreen}" BorderThickness="1"
                            CornerRadius="8" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="PRESCRIBED DRILL" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentGreen}"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="FirstDrillName" Text=""
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}"/>
                            <TextBlock x:Name="FirstDrillCue" Text=""
                                       FontSize="12" FontStyle="Italic"
                                       Foreground="{DynamicResource MutedText}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ═══════════ Footer ═══════════ -->
            <Grid Grid.Row="2" Margin="36,16,36,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StepIndicator" Text=""
                           FontSize="11"
                           Foreground="{DynamicResource MutedText}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="SkipBtn"
                        Content="Skip setup"
                        Click="Skip_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedText}"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="3" x:Name="PrimaryBtn"
                        Content="Start calibration"
                        Click="Primary_Click"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="#07090C"
                        FontWeight="Bold"
                        FontSize="13"
                        BorderThickness="0"
                        Padding="20,10"
                        Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>
