<Window x:Class="CleanAimTracker.Windows.UpgradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade to Pro"
        Height="620" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">

    <Border Background="{DynamicResource AppBackground}" Padding="32 28">
        <StackPanel>

            <!-- Header -->
            <TextBlock Text="🚀  Unlock Full Access"
                       FontSize="22" FontWeight="Black"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 8"/>
            <TextBlock Text="One payment. Everything unlocked. Forever."
                       FontSize="13"
                       Foreground="{DynamicResource MutedText}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 28"/>

            <!-- Feature list -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="10" Padding="20 16" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="WHAT YOU GET WITH PRO"
                               Foreground="{DynamicResource MutedText}"
                               FontSize="10" FontWeight="Bold"
                               Margin="0 0 0 12"/>
                    <TextBlock Text="✅  Full session history"
                               Foreground="{DynamicResource PrimaryText}" FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  AI coaching after every drill"
                               Foreground="{DynamicResource PrimaryText}" FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  Sensitivity recommendations"
                               Foreground="{DynamicResource PrimaryText}" FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  In-game overlay"
                               Foreground="{DynamicResource PrimaryText}" FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅✅  Aim Trainer — all scenarios &amp; difficulties  (Pro + Trainer)"
                               Foreground="{DynamicResource PrimaryText}" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Pro Monthly button -->
            <Button x:Name="ProBtn"
                    Click="Pro_Click"
                    Height="48"
                    Background="#2D6A4F"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0 0 0 8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pro  — " VerticalAlignment="Center"/>
                    <TextBlock Text="$5.99 / mo" FontSize="15" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Pro + Trainer Monthly button -->
            <Button x:Name="ProTrainerBtn"
                    Click="ProTrainer_Click"
                    Height="48"
                    Background="#1B4332"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0 0 0 8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pro + Trainer  — " VerticalAlignment="Center"/>
                    <TextBlock Text="$8.99 / mo" FontSize="15" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Lifetime purchase button -->
            <Button x:Name="LifetimeBtn"
                    Click="Lifetime_Click"
                    Height="52"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="Black"
                    FontWeight="Black"
                    FontSize="15"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0 0 0 8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Lifetime Pro  — " VerticalAlignment="Center"/>
                    <TextBlock Text="$39.99" FontSize="17" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Text="Subscriptions auto-renew monthly · Cancel anytime · Lifetime = one-time purchase"
                       Foreground="{DynamicResource MutedText}"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0 0 0 16"/>

            <!-- Cancel -->
            <Button Content="Maybe Later"
                    Click="Cancel_Click"
                    Height="36"
                    Background="Transparent"
                    Foreground="{DynamicResource MutedText}"
                    FontSize="13"
                    BorderThickness="1"
                    BorderBrush="#333"
                    Cursor="Hand"/>

        </StackPanel>
    </Border>
</Window>
