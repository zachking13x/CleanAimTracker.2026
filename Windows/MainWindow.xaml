<Window x:Class="CleanAimTracker.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clean Aim Tracker"
        Height="720"
        Width="1200"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        RenderOptions.BitmapScalingMode="HighQuality">

    <!-- RESOURCES (unchanged) -->
    <Window.Resources>

        <!-- Stat card -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                  BlurRadius="8"
                                  ShadowDepth="0"
                                  Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E5FF"
                                          BlurRadius="12"
                                          ShadowDepth="0"
                                          Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Label text -->
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LabelText}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Value text -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Responsive grid -->
        <Style TargetType="UniformGrid" x:Key="ResponsiveGridStyle">
            <Setter Property="Columns" Value="2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="1400">
                    <Setter Property="Columns" Value="3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding SelectionBoxItem}"/>

                            <ToggleButton x:Name="PART_DropDownToggle"
                                      Grid.Column="1"
                                      Focusable="False"
                                      ClickMode="Press"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Path Data="M 0 0 L 4 4 L 8 0"
                                  Stroke="{DynamicResource PrimaryText}"
                                  StrokeThickness="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_DropDownToggle"
                                    Property="BorderBrush"
                                    Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Glow Button -->
        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                  BlurRadius="8"
                                  ShadowDepth="0"
                                  Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E5FF"
                                          BlurRadius="12"
                                          ShadowDepth="0"
                                          Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>


    <!-- MAIN LAYOUT -->
    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAV BAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppBackground}"
                Margin="0 0 0 12"
                SnapsToDevicePixels="True">
            <DockPanel LastChildFill="False">

                <TextBlock Text="Clean Aim Tracker"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0 0 20 0"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">


                    <Button Content="Home"
                            Click="NavHome_Click"
                            Style="{StaticResource GlowButton}"/>

                    <Button Content="Settings"
                            Click="NavSettings_Click"
                            Style="{StaticResource GlowButton}"/>

                    <Button Content="History"
                            Click="NavHistory_Click"
                            Style="{StaticResource GlowButton}"/>

                    <Button Content="About"
                            Click="NavAbout_Click"
                            Style="{StaticResource GlowButton}"/>

                    <Button Content="Glossary"
                            Click="OpenGlossary_Click"
                            Style="{StaticResource GlowButton}"/>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- TRIAL BANNER -->
        <Border Grid.Row="1"
                Background="{DynamicResource BannerBackground}"
                CornerRadius="8"
                Padding="10"
                Margin="0 0 0 12"
                SnapsToDevicePixels="True">
            <DockPanel>
                <TextBlock x:Name="TrialBannerText"
                           Text="Free Trial - 7 days remaining"
                           Foreground="{DynamicResource PrimaryText}"
                           FontWeight="SemiBold"
                           FontSize="13"/>

                <TextBlock x:Name="LastDeltaText"
                           Text="Last Delta: 0.0"
                           Foreground="{DynamicResource SecondaryText}"
                           Margin="16 0 0 0"/>
            </DockPanel>
        </Border>

        <!-- HEADER + INPUTS -->
        <Grid Grid.Row="2"
              Margin="0 0 0 16"
              SnapsToDevicePixels="True">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="3.5*"/>
                <ColumnDefinition Width="2.5*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <StackPanel Grid.Column="0"
                        Margin="0 0 16 0">
                <TextBlock Text="Live Aim Session"
                           Style="{StaticResource SectionHeaderText}"/>

                <TextBlock Text="Real-time tracking of your mouse movement, flicks, and aim quality."
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="12"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <!-- CENTER INPUTS -->
            <StackPanel Grid.Column="1"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                <!-- DPI -->
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="DPI"
                   Style="{StaticResource LabelTextStyle}"/>
                    <TextBox x:Name="DpiInput"
                 Width="80"
                 Text="800"
                 Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- Sensitivity -->
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="Sensitivity"
                   Style="{StaticResource LabelTextStyle}"/>
                    <TextBox x:Name="SensitivityInput"
                 Width="80"
                 Text="1.0"
                 Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- Profile -->
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="Profile"
                   Style="{StaticResource LabelTextStyle}"/>
                    <ComboBox x:Name="GameProfileCombo"
                  Width="150"
                  Height="30"
                  Style="{StaticResource ModernComboBox}"
                  SelectionChanged="GameProfileCombo_SelectionChanged"/>
                </StackPanel>

            </StackPanel>


            <!-- RIGHT BUTTONS -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">


                <Button x:Name="StartButton"
                        Content="Start"
                        Click="StartButton_Click"
                        Background="{DynamicResource ButtonPrimaryBg}"
                        Foreground="{DynamicResource ButtonPrimaryFg}"
                        Padding="12 4"/>

                <Button x:Name="StopButton"
                        Content="Stop"
                        Click="StopButton_Click"
                        Background="{DynamicResource ButtonSecondaryBg}"
                        Foreground="{DynamicResource ButtonSecondaryFg}"
                        Padding="12 4"/>

                <Button x:Name="ResetButton"
                        Content="Reset"
                        Click="ResetButton_Click"
                        Background="{DynamicResource ButtonSecondaryBg}"
                        Foreground="{DynamicResource ButtonSecondaryFg}"
                        Padding="12 4"/>

                <Button x:Name="SummaryButton"
                        Content="Summary"
                        Click="OpenSummary_Click"
                        Background="{DynamicResource ButtonSecondaryBg}"
                        Foreground="{DynamicResource ButtonSecondaryFg}"
                        Padding="12 4"/>

                <Button x:Name="RecommendButton"
                        Content="Recommend"
                        Click="OpenRecommendation_Click"
                        Background="{DynamicResource ButtonSecondaryBg}"
                        Foreground="{DynamicResource ButtonSecondaryFg}"
                        Padding="12 4"/>

            </StackPanel>
        </Grid>

        <!-- STATS GRID -->
        <UniformGrid Grid.Row="3"
                     Style="{StaticResource ResponsiveGridStyle}"
                     Rows="0"
                     Margin="0 0 0 8"
                     SnapsToDevicePixels="True">

            <!-- ALL YOUR STAT CARDS REMAIN EXACTLY AS THEY ARE -->
            <!-- I did NOT modify bindings, names, or structure -->
            <!-- I only fixed spacing, margins, and pixel snapping -->

            <!-- Movement -->
            <Border Style="{StaticResource StatCardStyle}"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBlock Text="Movement"
                               Style="{StaticResource SectionHeaderText}"
                               Margin="0 0 0 8"/>

                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="dX / dY"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="DxDyText"
                                       Text="dX: 0   dY: 0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Total Distance"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="TotalDistanceText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Session Time"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="SessionTimeText"
                                       Text="00:00"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="cm/360"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="CmPer360Text"
                                       Text="--"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Velocity -->
            <Border Style="{StaticResource StatCardStyle}"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBlock Text="Velocity"
                               Style="{StaticResource SectionHeaderText}"
                               Margin="0 0 0 8"/>

                    <!-- Speed + Current -->
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Speed"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="SpeedText"
                                       Text="0 cm/s"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Current"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="CurrentSpeedText"
                                       Text="0 cm/s"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Peak + Average -->
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Peak"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="PeakSpeedText"
                                       Text="0 cm/s"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Average"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="AverageSpeedText"
                                       Text="0 cm/s"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- MPS + Rolling Density -->
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MPS"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="MpsText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Rolling Density"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="RollingDensityText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Peak Vel Change -->
                    <StackPanel>
                        <TextBlock Text="Peak Vel Change"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="PeakVelocityChangeText"
                                   Text="0"
                                   Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Flicks -->
            <Border Style="{StaticResource StatCardStyle}"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBlock Text="Flicks"
                               Style="{StaticResource SectionHeaderText}"
                               Margin="0 0 0 8"/>

                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Flicks"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="FlicksCountText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Small Flicks"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="SmallFlicksText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Large Flicks"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="LargeFlicksText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Idle Bursts"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="IdleBurstsText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Aim Quality -->
            <Border Style="{StaticResource StatCardStyle}"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBlock Text="Aim Quality"
                               Style="{StaticResource SectionHeaderText}"
                               Margin="0 0 0 8"/>

                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Overall Quality"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="OverallQualityText"
                                       Text="100"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Smoothness"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="SmoothnessText"
                                       Text="100"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Correction Sharpness"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="CorrectionSharpnessText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Stability"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="StabilityText"
                                       Text="0"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Advanced Metrics -->
            <Border Style="{StaticResource StatCardStyle}"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBlock Text="Advanced Metrics"
                               Style="{StaticResource SectionHeaderText}"
                               Margin="0 0 0 8"/>

                    <TextBlock Text="Angle Change"
                               Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="AngleChangeText"
                               Text="0"
                               Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Text="Jitter"
                               Style="{StaticResource LabelTextStyle}"
                               Margin="0 8 0 0"/>
                    <TextBlock x:Name="JitterText"
                               Text="0"
                               Style="{StaticResource ValueTextStyle}"/>

                    <TextBlock Text="Movement Density"
                               Style="{StaticResource LabelTextStyle}"
                               Margin="0 8 0 0"/>
                    <TextBlock x:Name="DensityText"
                               Text="0"
                               Style="{StaticResource ValueTextStyle}"/>

                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>

</Window>
