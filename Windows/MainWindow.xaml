<Window x:Class="CleanAimTracker.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clean Aim Tracker"
        Height="720"
        Width="1200"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        Icon="{StaticResource AppLogo}"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>

        <!-- Stat card — spec: CornerRadius 12, Layer 1 shadow -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section header — card title -->
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Label text — spec: 10px, SemiBold, TextMuted -->
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Value text — spec: 20px, Black weight, TextPrimary -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"
                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ToggleButton x:Name="PART_DropDownToggle" Grid.Column="1"
                                          Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Path Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource PrimaryText}"
                                      StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_DropDownToggle" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Glow Button -->
        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="12" ShadowDepth="0" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Nav Button Style — spec: 200px sidebar, 40px items, 16px padding,
             14px TextSecondary inactive, TextPrimary SemiBold active,
             3px AccentPrimary left bar active, BgElevated active bg,
             0.04 opacity hover tint -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Left accent bar — 3px, AccentPrimary when active -->
                            <Rectangle x:Name="ActiveBar"
                                       Width="3"
                                       Fill="Transparent"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Stretch"/>
                            <!-- Hover tint layer -->
                            <Border x:Name="HoverLayer"
                                    Background="Transparent"
                                    CornerRadius="0"/>
                            <Border x:Name="NavBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverLayer" Property="Background" Value="#0AFFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <!-- Active nav item — left cyan bar + BgElevated bg + SemiBold -->
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="NavBorder" Property="Background"
                                        Value="{StaticResource BgElevated}"/>
                                <Setter TargetName="ActiveBar" Property="Fill"
                                        Value="{StaticResource AccentPrimary}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark tooltip — matches app theme -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#1C1C1C"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10 7">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="#CCCCCC"
                                       FontSize="12"
                                       MaxWidth="240"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ROOT: Sidebar + Main -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- 5A: ANIMATED BACKGROUND ATMOSPHERE             -->
        <!-- ═══════════════════════════════════════════════ -->
        <Canvas x:Name="AtmosphereCanvas"
                Grid.ColumnSpan="2"
                IsHitTestVisible="False"
                Panel.ZIndex="-1"
                Opacity="0.07">
            <Ellipse Width="400" Height="400"
                     Canvas.Left="-100" Canvas.Top="-100">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#00D4FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="AtmosphereTransform"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- LEFT SIDEBAR                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgBase}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0"
                SnapsToDevicePixels="True">
            <DockPanel>

                <!-- TOP: Logo + App name -->
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,16">
                    <Image Source="{StaticResource AppLogo}" Width="36" Height="36"
                           HorizontalAlignment="Left" Stretch="Uniform" Margin="0 0 0 8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Clean Aim" Foreground="{DynamicResource PrimaryText}"
                                   FontSize="15" FontWeight="Bold" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="Tracker" Foreground="{DynamicResource AccentBrush}"
                               FontSize="15" FontWeight="Bold" Margin="0,-2,0,0"/>
                </StackPanel>

                <!-- BOTTOM: Theme toggle + Trial banner -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,12">

                    <!-- Trial Banner -->
                    <Border Background="{DynamicResource BannerBackground}"
                            CornerRadius="8" Padding="12,10"
                            Margin="0,0,0,8"
                            Cursor="Hand"
                            MouseDown="TrialBanner_Click">
                        <StackPanel>
                            <TextBlock x:Name="TrialBannerText"
                                       Text="Free Trial"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Tap to upgrade →"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme Toggle -->
                    <Button x:Name="ThemeToggleBtn"
                            Content="🌙  Dark Mode"
                            Click="ThemeToggle_Click"
                            Style="{StaticResource NavButtonStyle}"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- NAV BUTTONS -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="🏠  Home" Click="NavHome_Click" Style="{StaticResource NavButtonStyle}" Tag="Active"/>
                    <Button x:Name="NavHistoryBtn"
                            Content="📊  History" Click="NavHistory_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="AimTrainerNavBtn"
                            Content="🎯  Aim Trainer" Click="OpenAimTrainer_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{DynamicResource AccentBrush}"/>
                    <Button x:Name="NavAimTrainerReportBtn"
                            Content="🤖  Aim Coach Report" Click="ViewLastAimCoachReport_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="NavLastReportBtn"
                            Content="📋  Last Session Report" Click="ViewLastCoachReport_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="NavSensitivityBtn"
                            Content="🔄  Sensitivity" Click="OpenConverter_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📅  Weekly Report" Click="OpenWeeklyReport_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="NavAchievementsBtn"
                            Content="🏆  Achievements" Click="NavAchievements_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📤  Export Data" Click="OpenExport_Click" Style="{StaticResource NavButtonStyle}"/>

                    <!-- Thin separator -->
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="14,6"/>

                    <Button Content="⚙️  Settings" Click="NavSettings_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="ℹ️  About" Click="NavAbout_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📖  Glossary" Click="OpenGlossary_Click" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Margin="14,12,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: What's New banner -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: Controls card -->
                <RowDefinition Height="*"/>     <!-- Row 2: Stats + Player panel -->
            </Grid.RowDefinitions>

            <!-- BANNERS (Row 0) — What's New + Weekly Recap -->
            <StackPanel Grid.Row="0">

            <!-- WHAT'S NEW BANNER -->
            <Border x:Name="WhatsNewBanner"
                    Background="#1A00D4FF"
                    BorderBrush="#3300D4FF"
                    BorderThickness="0,0,0,1"
                    Padding="16,10"
                    Margin="0,0,0,10"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="🆕 "
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="WhatsNewVersionText"
                                   Text="What's new in v1.0.32"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock x:Name="WhatsNewBodyText"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{DynamicResource PrimaryText}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="✕"
                            Click="WhatsNewDismiss_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource SecondaryText}"
                            FontSize="13"
                            Padding="8,4"
                            Cursor="Hand"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- WEEKLY RECAP BANNER -->
            <Border x:Name="WeeklyRecapBanner"
                    Background="#1A4CAF50"
                    BorderBrush="#334CAF50"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8"
                    Padding="16,10"
                    Margin="0,0,0,10"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="📊 "
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="WeeklyRecapTitleText"
                                   Text="Last week recap"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="LightGreen"/>
                        <TextBlock x:Name="WeeklyRecapBodyText"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{DynamicResource PrimaryText}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="✕"
                            Click="WeeklyRecapDismiss_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource SecondaryText}"
                            FontSize="13"
                            Padding="8,4"
                            Cursor="Hand"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            </StackPanel><!-- end banners StackPanel -->

            <!-- CONTROLS CARD -->
            <Border Grid.Row="1"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="12"
                    Padding="20,14"
                    Margin="0,0,0,14"
                    SnapsToDevicePixels="True">
                <StackPanel>

                    <!-- Row 1: Inputs -->
                    <DockPanel Margin="0,0,0,10">
                        <!-- LastDeltaText on far right -->
                        <TextBlock x:Name="LastDeltaText"
                                   DockPanel.Dock="Right"
                                   Text="Last Delta: 0.0"
                                   Foreground="{DynamicResource SecondaryText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>

                        <!-- DPI -->
                        <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                            <TextBlock Text="DPI" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,0,0,3"
                                       ToolTip="Your mouse hardware DPI setting. Check your mouse software or physical DPI button. Common values: 400, 800, 1600, 3200."/>
                            <TextBox x:Name="DpiInput" Width="80" Text="800"
                                     Style="{StaticResource ModernTextBox}"
                                     LostFocus="DpiInput_LostFocus"/>
                        </StackPanel>

                        <!-- Sensitivity -->
                        <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                            <TextBlock Text="SENSITIVITY" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,0,0,3"
                                       ToolTip="Your in-game sensitivity value. Used to calculate cm/360 and generate sensitivity-specific coaching advice."/>
                            <TextBox x:Name="SensitivityInput" Width="80" Text="1.0"
                                     Style="{StaticResource ModernTextBox}"
                                     LostFocus="SensitivityInput_LostFocus"/>
                        </StackPanel>

                        <!-- Profile -->
                        <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                            <TextBlock Text="PROFILE" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="GameProfileCombo" Width="150" Height="30"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="GameProfileCombo_SelectionChanged"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Row 2: Buttons + Recording Indicator -->
                    <DockPanel>
                        <!-- Recording indicator (right) -->
                        <StackPanel x:Name="RecordingPanel"
                                    DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="12,0,0,0">
                            <Ellipse Width="8" Height="8" Fill="#EF5350" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="LIVE" Foreground="#EF5350" FontWeight="Bold"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="SessionTimeText" Text="00:00"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Action buttons (left) -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="StartButton" Content="▶  Start"
                                    Click="StartButton_Click"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="StopButton" Content="■  Stop"
                                    Click="StopButton_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="ResetButton" Content="↺  Reset"
                                    Click="ResetButton_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="SummaryButton" Content="Summary"
                                    Click="OpenSummary_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="RecommendButton" Content="Recommend"
                                    Click="OpenRecommendation_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="ToggleOverlayButton" Content="👁  Overlay"
                                    Click="ToggleOverlay_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </DockPanel>

                </StackPanel>
            </Border>

            <!-- STATS GRID + PLAYER PANEL (side-by-side, Row 2) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

            <!-- STATS GRID (3 columns, 2 rows) -->
            <UniformGrid Grid.Column="0" Columns="3" Rows="2" SnapsToDevicePixels="True">

                <!-- ── Row 1, Col 1: Movement ── -->
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource CardBgCyan}" BorderBrush="{StaticResource AccentPrimary}" BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="Movement" Style="{StaticResource SectionHeaderText}"
                                   Foreground="{StaticResource AccentPrimary}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="dX / dY" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Raw mouse delta — the X and Y axis movement your mouse reported each poll cycle."/>
                                <TextBlock x:Name="DxDyText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentPrimary}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Total Distance" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Total raw mouse units moved this session. Higher means more physical mouse movement overall."/>
                                <TextBlock x:Name="TotalDistanceText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentPrimary}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- Primary: game sensitivity -->
                                <TextBlock x:Name="SensDisplayLabel"
                                           Text="Sensitivity"
                                           Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Your equivalent in-game sensitivity for the selected game profile. Change your game's sensitivity to this number."/>
                                <TextBlock x:Name="SensDisplayText"
                                           Text="--"
                                           Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentPrimary}"/>
                                <!-- Secondary: cm/360 for context -->
                                <TextBlock x:Name="CmPer360Text"
                                           Text="--"
                                           FontSize="10"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,-8,0,8"
                                           ToolTip="Centimeters of physical desk movement for one full 360° turn. Most players prefer 20–50 cm/360."/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Session Time" Style="{StaticResource LabelTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Verdict line — populated after session ends -->
                        <TextBlock x:Name="MovementVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 1, Col 2: Velocity ── -->
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource CardBgAmber}" BorderBrush="{StaticResource AccentWarm}" BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="Velocity" Style="{StaticResource SectionHeaderText}"
                                   Foreground="{StaticResource AccentWarm}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Speed" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="SpeedText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="CurrentSpeedText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Peak" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="PeakSpeedText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Average" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="AverageSpeedText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MPS" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Mouse Movements Per Second — how actively your mouse was moving this session."/>
                                <TextBlock x:Name="MpsText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Rolling Density" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Micro-movements per second over the last 1-second window — indicates aim tremor or active micro-adjustment patterns."/>
                                <TextBlock x:Name="RollingDensityText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Peak Vel Change" Style="{StaticResource LabelTextStyle}"
                                       ToolTip="Largest sudden velocity change this session — high values mean fast, explosive flick shots."/>
                            <TextBlock x:Name="PeakVelocityChangeText" Text="--" Style="{StaticResource ValueTextStyle}"
                                       Foreground="{StaticResource AccentWarm}"/>
                        </StackPanel>

                        <!-- Verdict line -->
                        <TextBlock x:Name="VelocityVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 1, Col 3: Flicks ── -->
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource CardBgAmber}" BorderBrush="{StaticResource AccentWarm}" BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="Flicks" Style="{StaticResource SectionHeaderText}"
                                   Foreground="{StaticResource AccentWarm}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Flicks" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="FlicksCountText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Small Flicks" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="SmallFlicksText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Large Flicks" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="LargeFlicksText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Idle Bursts" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Fast movements that start from near-stillness — indicates reactive, instinctive aim from a stationary position."/>
                                <TextBlock x:Name="IdleBurstsText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentWarm}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Row 2, Col 1: Aim Quality ── -->
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource CardBgGreen}" BorderBrush="{StaticResource AccentGreen}" BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="Aim Quality" Style="{StaticResource SectionHeaderText}"
                                   Foreground="{StaticResource AccentGreen}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Overall Quality" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Composite aim score 0–100 based on smoothness, control, and correction consistency. 70+ is solid; 85+ is elite."/>
                                <TextBlock x:Name="OverallQualityText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentGreen}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Smoothness" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="How fluid and continuous your movement is. High = fewer jerky direction changes. Aim for 65+."/>
                                <TextBlock x:Name="SmoothnessText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentGreen}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Correction Sharpness" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="How aggressively you correct your aim. Very high (80+) may mean you're overshooting targets; very low (&lt;20) may mean slow, hesitant adjustments."/>
                                <TextBlock x:Name="CorrectionSharpnessText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentGreen}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Stability" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="How steady your aim is during slow movement or pauses. Higher is better for tracking scenarios."/>
                                <TextBlock x:Name="StabilityText" Text="--" Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource AccentGreen}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Verdict line -->
                        <TextBlock x:Name="QualityVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 2, Col 2: Advanced Metrics ── -->
                <Border Style="{StaticResource StatCardStyle}" Background="{StaticResource CardBgPurple}" BorderBrush="{StaticResource AccentPurple}" BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="Advanced Metrics" Style="{StaticResource SectionHeaderText}"
                                   Foreground="{StaticResource AccentPurple}" Margin="0,0,0,8"/>

                        <TextBlock Text="Angle Change" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="AngleChangeText" Text="--" Style="{StaticResource ValueTextStyle}"
                                   Foreground="{StaticResource AccentPurple}"/>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <TextBlock Text="Jitter" Style="{StaticResource LabelTextStyle}"
                                   ToolTip="Rapid involuntary micro-movements that aren't intentional aim. High jitter can indicate grip tension, fatigue, or sensitivity set too high."/>
                        <TextBlock x:Name="JitterText" Text="--" Style="{StaticResource ValueTextStyle}"
                                   Foreground="{StaticResource AccentPurple}"/>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <TextBlock Text="Movement Density" Style="{StaticResource LabelTextStyle}"
                                   ToolTip="Active movement events per second across the full session — how busy your aim is over time."/>
                        <TextBlock x:Name="DensityText" Text="--" Style="{StaticResource ValueTextStyle}"
                                   Foreground="{StaticResource AccentPurple}"/>

                        <!-- Verdict line -->
                        <TextBlock x:Name="SmoothnessVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 2, Col 3: Quick Launch ── -->
                <Border x:Name="TodayStatsCard" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <!-- Header row with tier badge (kept for code-behind compatibility) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Today" Style="{StaticResource SectionHeaderText}"
                                       Grid.Column="0"/>
                            <Border Grid.Column="1" x:Name="TierBadge"
                                    CornerRadius="6" Padding="8,3"
                                    Background="#1A1A1A">
                                <TextBlock x:Name="TierText"
                                           Text="Rookie"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#888888"/>
                            </Border>
                        </Grid>

                        <!-- Stats row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SESSIONS" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="TodaySessionsText" Text="—" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="BEST QUALITY" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="BestQualityTodayText" Text="—" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Weekly avg (hidden but kept for code-behind compat) -->
                        <TextBlock x:Name="WeeklyAvgText" Visibility="Collapsed"/>
                        <!-- Streak (hidden, now in Player Panel) -->
                        <StackPanel x:Name="StreakPanel" Visibility="Collapsed">
                            <TextBlock x:Name="StreakText"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,10"/>

                        <!-- Quick Launch button — 5E: gentle breathing pulse -->
                        <Button x:Name="StartTrainingBtn"
                                Content="🎯  Start Training"
                                Click="OpenAimTrainer_Click"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold"
                                Padding="12,8"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="1.0" To="0.75"
                                                Duration="0:0:1.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Session context line -->
                        <TextBlock x:Name="SessionContextText"
                                   Text=""
                                   FontSize="10"
                                   Foreground="{DynamicResource SecondaryText}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- PLAYER PANEL (right column) -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="14,0,0,0">
                <StackPanel x:Name="PlayerPanel">

                    <!-- ── COACH REPORT BANNER: appears after 45s+ session ends ── -->
                    <Border x:Name="CoachReportBanner"
                            Background="#1400D4FF"
                            BorderBrush="#4400D4FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋 " FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Session complete"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AccentPrimary}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="View your coaching report"
                                           FontSize="10"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Open →"
                                    Click="CoachReportBannerBtn_Click"
                                    Height="28"
                                    Padding="10,6"
                                    Margin="0"
                                    FontSize="11" FontWeight="Bold"
                                    Cursor="Hand"
                                    VerticalAlignment="Center">
                                <Button.Background>
                                    <SolidColorBrush Color="#00D4FF"/>
                                </Button.Background>
                                <Button.Foreground>
                                    <SolidColorBrush Color="Black"/>
                                </Button.Foreground>
                                <Button.BorderThickness>
                                    <Thickness>0</Thickness>
                                </Button.BorderThickness>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── TASK-03: WHAT TO DO NEXT HINT (first 5 sessions) ── -->
                    <Border x:Name="NextActionHint"
                            Background="#0A1F0A"
                            BorderBrush="#2ECC71"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👇 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="NextActionHintText"
                                       Text="Try today's challenge to earn your first achievement!"
                                       FontSize="12"
                                       Foreground="#2ECC71"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ── TASK-08: Tier Hero Card ─────────────────────── -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <!-- tier badge row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock x:Name="TierEmojiText" Text="🎮"
                                           FontSize="26" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TierNameText" Text="Rookie"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock x:Name="TierAvgText" Text="No sessions yet"
                                               FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- progress bar -->
                            <ProgressBar x:Name="TierProgressBar"
                                         Minimum="0" Maximum="100" Value="0"
                                         Height="6" Margin="0,0,0,4"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource SeparatorBrush}"
                                         BorderThickness="0"/>
                            <TextBlock x:Name="TierNextGoalText"
                                       Text="Complete your first session"
                                       FontSize="10" Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── TASK-09: Streak Card ────────────────────────── -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="TRAINING STREAK"
                                       FontSize="9" FontWeight="Bold"                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="StreakValueText" Text="0"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"
                                           Margin="0,0,6,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="StreakFlameText" Text="🔥"
                                               FontSize="18"/>
                                    <TextBlock Text="days" FontSize="11"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="BestStreakText"
                                       Text="Best: 0 days"
                                       FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── TASK-02 + TASK-10: Daily Challenge Card ────── -->
                    <Border x:Name="DailyChallengeCardBorder"
                            Margin="0,0,0,8"
                            CornerRadius="12"
                            Cursor="Hand"
                            MouseDown="DailyChallenge_Click"
                            SnapsToDevicePixels="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1F2D" Offset="0"/>
                                <GradientStop Color="#0A1A28" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00D4FF" Offset="0"/>
                                <GradientStop Color="#0066AA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1.5</Thickness>
                        </Border.BorderThickness>
                        <Border.Effect>
                            <DropShadowEffect Color="#00D4FF" BlurRadius="12"
                                              ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#00D4FF" BlurRadius="20"
                                                                  ShadowDepth="0" Opacity="0.45"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel Margin="14,12">
                            <!-- Header row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="⚡ " FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="DAILY CHALLENGE"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentPrimary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="ChallengeStatusBadge"
                                           Text=" · Active"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#7AABBB"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Challenge description -->
                            <TextBlock x:Name="ChallengeDescText"
                                       Text="Loading challenge..."
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>

                            <!-- Challenge countdown — only visible within 12 hours of midnight -->
                            <TextBlock x:Name="ChallengeCountdownText"
                                       Text=""
                                       FontSize="10"
                                       Foreground="{DynamicResource MutedText}"
                                       Margin="0,0,0,8"
                                       Visibility="Collapsed"/>

                            <!-- Start button -->
                            <Button x:Name="ChallengeAcceptBtn"
                                    Content="▶  Start Challenge"
                                    Click="DailyChallenge_Click"
                                    Foreground="Black"
                                    BorderThickness="0"
                                    FontSize="12" FontWeight="Bold"
                                    Padding="12,7"
                                    Cursor="Hand"
                                    HorizontalAlignment="Stretch">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00D4FF" Offset="0"/>
                                        <GradientStop Color="#0099CC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.88"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Completed state -->
                            <TextBlock x:Name="ChallengeDoneText"
                                       Text="✓  Completed today — come back tomorrow!"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#4CAF50"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- ── TASK-11: Achievement Badge Row ─────────────── -->
                    <Border Style="{StaticResource StatCardStyle}"
                            Cursor="Hand" MouseDown="AchievementPanel_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <TextBlock Text="ACHIEVEMENTS"
                                           FontSize="9" FontWeight="Bold"                                           Foreground="{DynamicResource SecondaryText}"/>
                                <TextBlock x:Name="AchievementCountText"
                                           Text="  0 / 29"
                                           FontSize="9"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                            <!-- recent badge emojis -->
                            <ItemsControl x:Name="AchievementBadges">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border ToolTip="{Binding Name}"
                                                Margin="2" Padding="4,2"
                                                Background="{DynamicResource SeparatorBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding Emoji}" FontSize="16"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="AchievementEmptyText"
                                       Text="Complete drills to earn achievements"
                                       FontSize="10" Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            </Grid><!-- end stats+panel grid -->

        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ONBOARDING OVERLAY — 3s countdown, first session only   -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border x:Name="OnboardingOverlay"
                Grid.ColumnSpan="2"
                Background="#CC000000"
                Visibility="Collapsed"
                Panel.ZIndex="100">
            <Border Background="#0D0D1A"
                    BorderBrush="#2A2A4A"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="52 44"
                    MaxWidth="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="GET READY"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="11" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 18"/>

                    <TextBlock Text="Follow the target and click it when your crosshair is on it. We'll analyze your aim for 90 seconds and show you your results."
                               Foreground="White"
                               FontSize="16" FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="380"
                               Margin="0 0 0 32"/>

                    <!-- Countdown number -->
                    <TextBlock x:Name="OnboardingCountdownText"
                               Text="3"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="72" FontWeight="Black"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 28"/>

                    <!-- Got it button -->
                    <Button x:Name="OnboardingGotItBtn"
                            Content="Got it →"
                            Click="OnboardingGotIt_Click"
                            Height="44" Width="160"
                            HorizontalAlignment="Center"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- AIM TRAINER NAV HIGHLIGHT — shown after first session     -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="AimTrainerHighlight"
              Grid.ColumnSpan="2"
              Panel.ZIndex="99"
              Visibility="Collapsed"
              MouseDown="AimTrainerHighlight_Click"
              Cursor="Hand">

            <!-- Dim the rest of the window -->
            <Rectangle Fill="#99000000"/>

            <!-- Callout card — Margin set in code to align with nav button -->
            <Border x:Name="AimTrainerCallout"
                    Background="#0F1F0F"
                    BorderBrush="#3A7A3A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14 11"
                    MaxWidth="220"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Come back here to train anytime."
                               Foreground="LightGreen"
                               FontSize="12" FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Tap anywhere to dismiss"
                               Foreground="#555555"
                               FontSize="10"
                               Margin="0 5 0 0"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- GUIDED TOUR OVERLAY — runs once after first session      -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="TourOverlay"
              Grid.ColumnSpan="2"
              Panel.ZIndex="103"
              Visibility="Collapsed"
              MouseDown="TourOverlay_MouseDown">

            <!-- Full-screen dim -->
            <Rectangle Fill="#CC000000"/>

            <!-- Cyan highlight ring — size + position set in code per step -->
            <Border x:Name="TourHighlight"
                    BorderBrush="#00E5FF"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="#1000E5FF"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- Bubble card — positioned next to highlighted element -->
            <Border x:Name="TourBubble"
                    Background="#111111"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14 12"
                    MaxWidth="240"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    MouseDown="TourBubble_MouseDown">
                <StackPanel>
                    <TextBlock x:Name="TourBubbleText"
                               Foreground="White"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0 0 0 12"/>
                    <Button x:Name="TourNextBtn"
                            Content="Next →"
                            Click="TourNext_Click"
                            Height="28" Width="88"
                            HorizontalAlignment="Right"
                            FontSize="12" FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Final "You are set up" screen -->
            <Border x:Name="TourFinalCard"
                    Background="#0D0D1A"
                    BorderBrush="#1A1A3A"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="44 36"
                    MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    MouseDown="TourBubble_MouseDown">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="✓"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 16"/>
                    <TextBlock Text="You are set up."
                               Foreground="White"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 10"/>
                    <TextBlock Text="Come back daily for 5 minutes and your aim will improve. Your coach is already analyzing your data."
                               Foreground="#AAAAAA"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="360"
                               Margin="0 0 0 28"/>
                    <Button Content="Let's go"
                            Click="TourLetsGo_Click"
                            Height="42" Width="140"
                            HorizontalAlignment="Center"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>

    </Grid>

</Window>
