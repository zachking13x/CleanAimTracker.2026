<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Recommendation"
        Width="520"
        Height="760"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="Recommended Settings"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <!-- Sensitivity -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Sensitivity"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="SensValue"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>

                    <TextBlock x:Name="SensRange"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- DPI -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="DPI"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="DpiValue"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- cm/360 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="cm/360 (Your Real Sensitivity)"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="Cm360Value"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>

                    <TextBlock x:Name="Cm360Verdict"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,2,0,0"/>

                    <!-- Explanation block -->
                    <TextBlock Text="What is cm/360?"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"
                               Margin="0,12,0,0"/>

                    <TextBlock Text="cm/360 tells you how far you move your mouse to turn your character 360 degrees. Higher values give more control; lower values feel faster but harder to stabilize."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Confidence -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Confidence"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="ConfidenceValue"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Explanation -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Explanation"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="ExplanationText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tips -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Tips"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ItemsControl x:Name="TipsList"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="•  {Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="0,4,0,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Trend -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Trend Analysis"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TrendText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Close -->
            <Button Content="Close"
                    Click="Close_Click"
                    Style="{StaticResource GlowButton}"
                    HorizontalAlignment="Center"
                    Width="140"
                    Margin="0,16,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
