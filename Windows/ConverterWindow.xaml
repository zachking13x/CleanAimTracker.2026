<Window x:Class="CleanAimTracker.Windows.ConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Converter"
        Height="400"
        Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Sensitivity Converter"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <TextBox Width="300"
                     Margin="0 0 0 10"
                     TextChanged="OnInputChanged"/>

            <Button Content="Copy Result"
                    Width="150"
                    Margin="0 0 0 10"
                    Click="CopyResult_Click"/>

            <Button Content="Close"
                    Width="150"
                    Click="Close_Click"/>

        </StackPanel>
    </Grid>
</Window>
