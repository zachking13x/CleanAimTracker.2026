<Window x:Class="CleanAimTracker.Windows.OnboardingCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanAimTracker — Setup"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">

    <Border Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource HeaderBackground}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="CLEAN AIM TRACKER — FIRST RUN SETUP"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="16,10"/>
                <Button Grid.Column="1" Content="✕"
                        x:Name="CloseBtn"
                        Click="Skip_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedText}"
                        BorderThickness="0"
                        FontSize="14"
                        Margin="0,0,12,0"
                        Cursor="Hand"/>
            </Grid>

            <!-- Page content -->
            <Grid Grid.Row="1" Margin="32,24,32,0">

                <!-- PAGE 0: Welcome -->
                <StackPanel x:Name="PageWelcome" Visibility="Visible">
                    <TextBlock Text="Welcome to CleanAimTracker"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               LineHeight="20"
                               Margin="0,0,0,16">
                        CleanAimTracker measures your real mouse mechanics — smoothness, consistency, flick patterns — and connects them to your in-game performance.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               LineHeight="20">
                        The coach learns from your sessions over time. The more you play, the more specific and useful the feedback becomes.
                    </TextBlock>
                </StackPanel>

                <!-- PAGE 1: CalibrationBrief -->
                <StackPanel x:Name="PageCalibrationBrief" Visibility="Collapsed">
                    <TextBlock Text="Baseline calibration"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               LineHeight="20"
                               Margin="0,0,0,16">
                        We'll run three short aim trainer sessions to establish your starting baseline. This gives the coach real data to compare against your future sessions.
                    </TextBlock>
                    <Border Background="{DynamicResource CardBackground}"
                            CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="What gets measured:" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="  •  Accuracy and reaction time per scenario" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBlock Text="  •  Correction patterns and movement quality" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBlock Text="  •  Your natural sensitivity range" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Takes about 5 minutes total."
                               FontSize="12" FontStyle="Italic"
                               Foreground="{DynamicResource MutedText}"/>
                </StackPanel>

                <!-- PAGE 2: CalibrationRunning -->
                <StackPanel x:Name="PageCalibrationRunning" Visibility="Collapsed">
                    <TextBlock Text="Ready to calibrate"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               LineHeight="20"
                               Margin="0,0,0,20">
                        The aim trainer will open. Run three sessions at whatever scenario feels natural — Tracking or Flicking are good starting points.
                    </TextBlock>
                    <Border Background="#0A00D4FF" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource PrimaryText}"
                                   LineHeight="20">
                            The coach won't give feedback yet — it needs a few sessions before it has enough data to say something useful.
                        </TextBlock>
                    </Border>
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource MutedText}"
                               LineHeight="18">
                        Click "Start Calibration" below to close this window and open the aim trainer. Come back after 3 sessions.
                    </TextBlock>
                </StackPanel>

                <!-- PAGE 3: FirstInsight -->
                <StackPanel x:Name="PageFirstInsight" Visibility="Collapsed">
                    <TextBlock Text="Calibration complete"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentGreen}"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               LineHeight="20"
                               Margin="0,0,0,16">
                        You now have a baseline. The coach will compare every future session against these numbers and flag real changes — not noise.
                    </TextBlock>
                    <Border Background="{DynamicResource CardBackground}"
                            CornerRadius="6" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="What happens next:" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="  •  Each session gets a quality score and trend line" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBlock Text="  •  The coach identifies one thing to improve per session" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBlock Text="  •  Percentile rankings unlock after 5 sessions" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- PAGE 4: FirstDrill -->
                <StackPanel x:Name="PageFirstDrill" Visibility="Collapsed">
                    <TextBlock Text="Your first drill"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               LineHeight="20"
                               Margin="0,0,0,20">
                        Start with Tracking — Medium. It's the best baseline scenario for measuring movement quality and builds a consistent foundation for all other scenarios.
                    </TextBlock>
                    <Border Background="#0A4CAF50" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="SUGGESTED STARTING DRILL" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentGreen}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Tracking — Medium" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Focus on smooth, deliberate movement. Accuracy over speed."
                                       FontSize="12" FontStyle="Italic"
                                       Foreground="{DynamicResource MutedText}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="You can always change scenarios — this is just where the data says to start."
                               FontSize="12"
                               Foreground="{DynamicResource MutedText}"
                               TextWrapping="Wrap"/>
                </StackPanel>

            </Grid>

            <!-- Navigation footer -->
            <Grid Grid.Row="2" Margin="32,16,32,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Page indicator dots -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot0" Width="7" Height="7" Margin="0,0,5,0"
                             Fill="{DynamicResource AccentBrush}"/>
                    <Ellipse x:Name="Dot1" Width="7" Height="7" Margin="0,0,5,0"
                             Fill="{DynamicResource MutedText}"/>
                    <Ellipse x:Name="Dot2" Width="7" Height="7" Margin="0,0,5,0"
                             Fill="{DynamicResource MutedText}"/>
                    <Ellipse x:Name="Dot3" Width="7" Height="7" Margin="0,0,5,0"
                             Fill="{DynamicResource MutedText}"/>
                    <Ellipse x:Name="Dot4" Width="7" Height="7"
                             Fill="{DynamicResource MutedText}"/>
                </StackPanel>

                <!-- Skip link (hidden on last pages) -->
                <Button Grid.Column="1" x:Name="SkipBtn"
                        Content="Skip setup"
                        Click="Skip_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedText}"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>

                <!-- Primary action button -->
                <Button Grid.Column="3" x:Name="NextBtn"
                        Content="Get started"
                        Click="Next_Click"
                        Style="{StaticResource GlowButton}"
                        Width="130"
                        Foreground="{DynamicResource AccentBrush}"
                        FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Border>
</Window>
