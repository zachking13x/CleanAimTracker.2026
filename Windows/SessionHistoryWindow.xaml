<Window x:Class="CleanAimTracker.SessionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session History" Width="820" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title + stats summary -->
        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Session History"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0 6 0 0">
                <TextBlock x:Name="TotalSessionsText"
                           Foreground="{DynamicResource MutedText}" FontSize="13"
                           Text="0 sessions recorded"/>
                <TextBlock Text="  •  " Foreground="{DynamicResource MutedText}" FontSize="13"/>
                <TextBlock x:Name="AvgQualityText"
                           Foreground="{DynamicResource MutedText}" FontSize="13"
                           Text="Avg quality: --"/>
                <TextBlock Text="  •  " Foreground="{DynamicResource MutedText}" FontSize="13"/>
                <TextBlock x:Name="TrendDirectionText"
                           Foreground="{DynamicResource AccentBrush}" FontSize="13"
                           Text=""/>
            </StackPanel>
        </StackPanel>

        <!-- Quality trend chart -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackground}"
                CornerRadius="8"
                Padding="16"
                Margin="0 0 0 12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="QUALITY SCORE TREND"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0 0 0 8"/>
                <Canvas x:Name="TrendChart" Grid.Row="1"
                        Background="Transparent"
                        SizeChanged="TrendChart_SizeChanged"/>
            </Grid>
        </Border>

        <!-- Session list -->
        <ListBox x:Name="SessionList" Grid.Row="2"
                 Background="{DynamicResource CardBackground}"
                 Foreground="{DynamicResource PrimaryText}"
                 BorderThickness="0"
                 SelectionChanged="SessionList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBackground}"
                            CornerRadius="6" Padding="12" Margin="2,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MMM dd yyyy  h:mm tt}'}"
                                           Foreground="{DynamicResource PrimaryText}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                    <TextBlock Text="{Binding ProfileName}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="12" Margin="0 0 12 0"/>
                                    <TextBlock Foreground="{DynamicResource LabelText}" FontSize="12">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:F0}s  |  Smoothness: {1:F0}  |  Flicks: {2}">
                                                <Binding Path="SessionSeconds"/>
                                                <Binding Path="SmoothnessScore"/>
                                                <Binding Path="FlickCount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- DPI x Sens -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12 0">
                                <TextBlock Text="{Binding DPI, StringFormat='{}{0} DPI'}"
                                           Foreground="{DynamicResource LabelText}" FontSize="11"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Sensitivity, StringFormat='Sens {0:F4}'}"
                                           Foreground="{DynamicResource LabelText}" FontSize="11"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>

                            <!-- Quality score badge -->
                            <Border Grid.Column="2"
                                    CornerRadius="6"
                                    Background="#1A00E5FF"
                                    Padding="8 4"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding OverallQualityScore, StringFormat='{}{0:F0}'}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Action buttons -->
        <WrapPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0 12 0 0">
            <Button Content="📋 View Summary" Click="ViewSession_Click"
                    Background="{DynamicResource ButtonPrimaryBg}"
                    Foreground="{DynamicResource ButtonPrimaryFg}"
                    FontWeight="Bold" FontSize="13"
                    Padding="16,8" Margin="4" BorderThickness="0" Cursor="Hand"/>
            <Button Content="⬇ Export Selected" Click="ExportSelected_Click"
                    Background="{DynamicResource ButtonSecondaryBg}"
                    Foreground="{DynamicResource ButtonSecondaryFg}"
                    FontSize="13" Padding="14,8" Margin="4" BorderThickness="0" Cursor="Hand"/>
            <Button Content="⬇ Export All" Click="ExportAll_Click"
                    Background="{DynamicResource ButtonSecondaryBg}"
                    Foreground="{DynamicResource ButtonSecondaryFg}"
                    FontSize="13" Padding="14,8" Margin="4" BorderThickness="0" Cursor="Hand"/>
            <Button Content="🗑 Delete" Click="DeleteSession_Click"
                    Background="{DynamicResource ButtonDangerBg}"
                    Foreground="{DynamicResource ButtonDangerFg}"
                    FontSize="13" Padding="14,8" Margin="4" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Close" Click="Close_Click"
                    Background="{DynamicResource ButtonSecondaryBg}"
                    Foreground="{DynamicResource ButtonSecondaryFg}"
                    FontSize="13" Padding="14,8" Margin="4" BorderThickness="0" Cursor="Hand"/>
        </WrapPanel>
    </Grid>
</Window>
