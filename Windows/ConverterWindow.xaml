<Window x:Class="CleanAimTracker.Windows.ConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Converter"
        Height="400"
        Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Sensitivity Converter"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <!-- ⭐ ADDED FIELDS BELOW ⭐ -->

            <TextBlock Text="Profile:" FontSize="14"/>
            <TextBox x:Name="ProfileNameText"
                     Width="300"
                     Height="28"
                     Margin="0 5 0 15"/>

            <TextBlock Text="DPI:" FontSize="14"/>
            <TextBox x:Name="DpiInput"
                     Width="300"
                     Height="28"
                     Margin="0 5 0 15"/>

            <TextBlock Text="Sensitivity:" FontSize="14"/>
            <TextBox x:Name="SensInput"
                     Width="300"
                     Height="28"
                     Margin="0 5 0 15"/>

            <!-- ⭐ END OF ADDED FIELDS ⭐ -->

            <TextBox Width="300"
                     Margin="0 0 0 10"
                     TextChanged="OnInputChanged"/>

            <Button Content="Copy Result"
                    Width="150"
                    Margin="0 0 0 10"
                    Click="CopyResult_Click"/>

            <Button Content="Close"
                    Width="150"
                    Click="Close_Click"/>

        </StackPanel>
    </Grid>
</Window>
