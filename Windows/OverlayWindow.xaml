<Window x:Class="CleanAimTracker.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="210"
        ShowInTaskbar="False"
        Loaded="Overlay_Loaded"
        LocationChanged="Overlay_LocationChanged">

    <Window.Resources>
        <Style x:Key="ControlBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="44"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="3 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#555555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="20"/>
            <Setter Property="Height"          Value="20"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CC3333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer card — fades when mouse leaves -->
    <Border x:Name="OuterBorder"
            Background="#1C1C1C"
            CornerRadius="12"
            Opacity="0.88"
            MouseEnter="Border_MouseEnter"
            MouseLeave="Border_MouseLeave"
            MouseDown="OverlayDrag">

        <StackPanel>

            <!-- ── HEADER ─────────────────────────────── -->
            <Grid Margin="10 8 8 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status dot -->
                <Ellipse x:Name="StatusDot"
                         Grid.Column="0"
                         Width="7" Height="7"
                         Fill="#444444"
                         VerticalAlignment="Center"
                         Margin="0 0 6 0"/>

                <!-- Status label + timer -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusLabel"
                               Text="READY"
                               Foreground="#555555"
                               FontSize="9"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0 0 6 0"/>
                    <TextBlock x:Name="TimerText"
                               Text="00:00"
                               Foreground="#555555"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Collapse toggle -->
                <Button x:Name="CollapseBtn"
                        Grid.Column="2"
                        Content="▲"
                        Click="Collapse_Click"
                        Style="{StaticResource IconBtn}"
                        Margin="0 0 2 0"/>

                <!-- Close -->
                <Button Grid.Column="3"
                        Content="✕"
                        Click="Close_Click"
                        Style="{StaticResource IconBtn}"/>
            </Grid>

            <!-- ── DIVIDER ─────────────────────────────── -->
            <Rectangle Height="1" Fill="#2E2E2E" Margin="0 0 0 0"/>

            <!-- ── STATS SECTION (collapsible) ───────────── -->
            <StackPanel x:Name="StatsSection" Margin="12 10 12 4">

                <!-- Quality score — big, color coded -->
                <TextBlock Text="QUALITY SCORE"
                           Foreground="#444444"
                           FontSize="8"
                           FontWeight="Bold"
                           Margin="0 0 0 2"/>

                <TextBlock x:Name="QualityText"
                           Text="—"
                           Foreground="#00D4FF"
                           FontSize="36"
                           FontWeight="Black"
                           Margin="0 0 0 10"/>

                <!-- Mini stats: Speed | Flicks | Smooth -->
                <Grid Margin="0 0 0 4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SPEED"
                                   Foreground="#444444"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Margin="0 0 0 2"/>
                        <TextBlock x:Name="VelocityText"
                                   Text="—"
                                   Foreground="#AAAAAA"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="FLICKS"
                                   Foreground="#444444"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Margin="0 0 0 2"/>
                        <TextBlock x:Name="FlicksText"
                                   Text="—"
                                   Foreground="#AAAAAA"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SMOOTH"
                                   Foreground="#444444"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Margin="0 0 0 2"/>
                        <TextBlock x:Name="SmoothnessText"
                                   Text="—"
                                   Foreground="#AAAAAA"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

            </StackPanel>

            <!-- ── DIVIDER ─────────────────────────────── -->
            <Rectangle Height="1" Fill="#2E2E2E"/>

            <!-- ── CONTROLS ───────────────────────────── -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="10 8 10 10">

                <Button Content="▶ Start"
                        Click="Start_Click"
                        Style="{StaticResource ControlBtn}"
                        Foreground="#00D4FF"
                        Width="60"/>

                <Button Content="■ Stop"
                        Click="Stop_Click"
                        Style="{StaticResource ControlBtn}"
                        Width="54"/>

                <Button Content="📊"
                        Click="Recommend_Click"
                        Style="{StaticResource ControlBtn}"
                        Width="36"
                        FontSize="14"/>

            </StackPanel>

        </StackPanel>
    </Border>

</Window>
