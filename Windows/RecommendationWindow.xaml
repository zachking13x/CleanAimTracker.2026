<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Recommendation"
        Width="900"
        Height="650"
        MinWidth="800"
        MinHeight="550"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Icon="{StaticResource AppLogo}"
        x:Name="RootWindow">

    <Border Background="{DynamicResource AppBackground}"
            CornerRadius="8"
            BorderBrush="#33000000"
            BorderThickness="1">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  Background="#22252A"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        Margin="10,0,6,0"
                        VerticalAlignment="Center"
                        CornerRadius="3"
                        Background="#00AFFF">
                    <TextBlock Text="CA"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="13"
                           Text="Sensitivity Recommendation" />

                <Button Grid.Column="2"
                        Width="32"
                        Height="24"
                        Margin="0,0,4,0"
                        Click="Minimize_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <TextBlock Text="–"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </Button>

                <Button Grid.Column="3"
                        Width="32"
                        Height="24"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <TextBlock Text="✕"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="12"/>
                </Button>
            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="16,10,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Recommended Settings"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Game:"
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,6,0"/>

                        <ComboBox x:Name="GameCombo"
                                  Width="200"
                                  ItemsSource="{Binding GameOptions, ElementName=RootWindow}"
                                  DisplayMemberPath="GameName"
                                  Background="{DynamicResource CardBackground}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  BorderBrush="#444"
                                  Padding="4,2"
                                  SelectionChanged="GameCombo_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- MAIN AREA -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN (bound to rec) -->
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">

                            <!-- Sensitivity -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Sensitivity"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4}}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- DPI -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="DPI"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding RecommendedDPI}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- cm/360 -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="cm/360 (Your Real Sensitivity)"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding RecommendedCm360, StringFormat={}{0:F2}}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Cm360Verdict}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Confidence -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Confidence"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Confidence, StringFormat={}{0}%}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Explanation -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Explanation"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Explanation}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- Tips -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Tips"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding Tips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryText}">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding ., Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- RIGHT COLUMN (bound to window) -->
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">

                            <!-- Settings to Apply -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>

                                    <TextBlock Text="Settings to Apply"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding GameSettingsLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- ADS / Scope -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14"
                                    Visibility="{Binding HasAdsScopeSection, ElementName=RootWindow, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>

                                    <TextBlock Text="ADS / Scope Settings"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding AdsScopeLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- Advanced -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>

                                    <TextBlock Text="Advanced Settings"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding AdvancedLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- Game Tips -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>

                                    <TextBlock Text="Tips for This Game"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding GameTipsLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryText}">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding ., Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">

                    <Button Content="Copy Settings"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource GlowButton}"
                            Click="CopySettings_Click"/>

                    <Button Content="Copy Comparison"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource GlowButton}"
                            Click="CopyComparison_Click"/>

                    <Button Content="Close"
                            Width="150"
                            Style="{StaticResource GlowButton}"
                            Click="Close_Click"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
