<Window x:Class="CleanAimTracker.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Clean Aim Tracker"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                Padding="28 24"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0 0 0 1">
            <StackPanel HorizontalAlignment="Center">
                <Image Source="{StaticResource AppLogo}"
                       Width="52" Height="52"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 12"/>
                <TextBlock Text="Clean Aim Tracker"
                           FontSize="26" FontWeight="Black"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionText"
                           Text="Version 1.0.15"
                           FontSize="12"
                           Foreground="{DynamicResource MutedText}"
                           HorizontalAlignment="Center"
                           Margin="0 4 0 0"/>
                <TextBlock Text="Real-time FPS aim analytics &amp; trainer"
                           FontSize="13"
                           Foreground="{DynamicResource SecondaryText}"
                           HorizontalAlignment="Center"
                           Margin="0 6 0 0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24 20">
            <StackPanel>

                <!-- Upgrade CTA -->
                <Border Background="#0D00D4FF"
                        CornerRadius="10"
                        BorderBrush="#2200D4FF"
                        BorderThickness="1"
                        Padding="16 14"
                        Margin="0 0 0 16"
                        Cursor="Hand"
                        MouseDown="UpgradeBanner_Click">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="🚀  Upgrade to Pro"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Unlock all features including AI coaching, full history, and the sensitivity converter."
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0 4 0 0"/>
                        </StackPanel>
                        <TextBlock Text="→"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="18" FontWeight="Bold"/>
                    </Grid>
                </Border>

                <!-- About -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 10">
                    <StackPanel>
                        <TextBlock Text="ABOUT"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="0 0 0 10"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="13" LineHeight="22">
Clean Aim Tracker captures raw mouse input to measure velocity, flicks, jitter, smoothness, and more — in real time, outside the game, with no modifications required. The built-in AI coach analyzes your aim data and gives you personalized advice after every session.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Trial Info -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 10">
                    <StackPanel>
                        <TextBlock Text="FREE TRIAL"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="0 0 0 10"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="13" LineHeight="22">
Clean Aim Tracker includes a 7-day free trial with full access to all features. After the trial period, a Pro subscription is required to access: Aim Trainer, Session History, Sensitivity Recommendations, and the In-Game Overlay. Core mouse tracking remains free.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Developer -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 10">
                    <StackPanel>
                        <TextBlock Text="DEVELOPER"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="0 0 0 10"/>
                        <TextBlock Text="Zach King"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="zachking13@outlook.com"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="13" Margin="0 4 0 0"/>
                        <TextBlock x:Name="PrivacyLink"
                                   Text="Privacy Policy"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="13" Margin="0 6 0 0"
                                   Cursor="Hand"
                                   TextDecorations="Underline"
                                   MouseDown="PrivacyLink_Click"/>
                    </StackPanel>
                </Border>

                <!-- Legal -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 10">
                    <StackPanel>
                        <TextBlock Text="LEGAL"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="0 0 0 10"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="12" LineHeight="20">
Not affiliated with, endorsed by, or associated with any game developer or publisher. All sensitivity calculations use publicly available mathematical constants.
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackground}"
                Padding="24 16"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0 1 0 0">
            <Button Content="Close"
                    Click="Close_Click"
                    HorizontalAlignment="Right"
                    Width="100" Height="36"
                    Background="Transparent"
                    Foreground="{DynamicResource MutedText}"
                    FontSize="13"
                    BorderThickness="1"
                    BorderBrush="#444"
                    Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
