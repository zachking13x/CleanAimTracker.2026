<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recommendation"
        Height="400"
        Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Sensitivity Recommendation"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Your recommendation will appear here."
                       Margin="0 0 0 20"/>

            <Button Content="Close"
                    Width="150"
                    Click="Close_Click"/>

        </StackPanel>
    </Grid>
</Window>
