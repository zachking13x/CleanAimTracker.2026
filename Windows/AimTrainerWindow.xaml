<Window x:Class="CleanAimTracker.Windows.AimTrainerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aim Trainer — Clean Aim Tracker"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <!-- Dark ComboBox for VARIANT / DIFFICULTY / DURATION -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"  Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <!-- Selected-item display -->
                            <Border Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <ContentPresenter Grid.Column="0"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{Binding SelectionBoxItem,
                                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- Drop arrow toggle -->
                            <ToggleButton Grid.Column="1"
                                          Focusable="False" ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen,
                                                      RelativeSource={RelativeSource TemplatedParent},
                                                      Mode=TwoWay}">
                                <Path Data="M 0 0 L 5 5 L 10 0"
                                      Stroke="{DynamicResource MutedText}"
                                      StrokeThickness="1.5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </ToggleButton>
                            <!-- Popup -->
                            <Popup Grid.ColumnSpan="2"
                                   x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="#444"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Padding"    Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ LEFT PANEL -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0 0 1 0">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <StackPanel Margin="16">

                    <!-- Logo / Title -->
                    <TextBlock Text="AIM TRAINER"
                               FontSize="18" FontWeight="Black"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0 16 0 4"/>
                    <TextBlock Text="Clean Aim Tracker"
                               FontSize="10"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0 0 0 20"/>

                    <!-- Scenario Selector -->
                    <TextBlock Text="SCENARIO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>

                    <!-- TRACKING — #00D4FF, difficulty 2/4 -->
                    <Border x:Name="ScenarioBtn_Tracking"
                            Tag="Tracking"
                            CornerRadius="12" Margin="0,0,0,6"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00D4FF" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#070F14" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                    Background="#1E00D4FF" VerticalAlignment="Center">
                                <TextBlock Text="👁️" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                <TextBlock Text="Tracking" Foreground="#F0F4F8"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="Follow moving targets — builds fluid mouse control"
                                           Foreground="#8A9BAE" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#4A5A6A"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#00D4FF"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#00D4FF"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#131B24"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#131B24"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- FLICKING — #FFB347, difficulty 3/4 -->
                    <Border x:Name="ScenarioBtn_Flicking"
                            Tag="Flicking"
                            CornerRadius="12" Margin="0,0,0,6"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FFB347" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#100D07" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                    Background="#1EFFB347" VerticalAlignment="Center">
                                <TextBlock Text="⚡" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                <TextBlock Text="Flicking" Foreground="#F0F4F8"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="Snap to new targets instantly — builds reaction speed"
                                           Foreground="#8A9BAE" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#4A5A6A"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FFB347"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FFB347"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FFB347"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#131B24"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- PRECISION — #00E5A0, difficulty 2/4 -->
                    <Border x:Name="ScenarioBtn_Precision"
                            Tag="Precision"
                            CornerRadius="12" Margin="0,0,0,6"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00E5A0" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#071410" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                    Background="#1E00E5A0" VerticalAlignment="Center">
                                <TextBlock Text="🎯" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                <TextBlock Text="Precision" Foreground="#F0F4F8"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="Click small static targets — builds micro-adjustment"
                                           Foreground="#8A9BAE" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#4A5A6A"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#00E5A0"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#00E5A0"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#131B24"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#131B24"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SWITCHING — #FF6B35, difficulty 4/4 -->
                    <Border x:Name="ScenarioBtn_Switching"
                            Tag="Switching"
                            CornerRadius="12" Margin="0,0,0,6"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF6B35" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#100906" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                    Background="#1EFF6B35" VerticalAlignment="Center">
                                <TextBlock Text="🔀" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                <TextBlock Text="Switching" Foreground="#F0F4F8"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="Multi-target speed — builds target acquisition"
                                           Foreground="#8A9BAE" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#4A5A6A"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FF6B35"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FF6B35"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FF6B35"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#FF6B35"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ADAPTIVE — #A855F7, difficulty 3/4 -->
                    <Border x:Name="ScenarioBtn_Adaptive"
                            Tag="Adaptive"
                            CornerRadius="12" Margin="0,0,0,6"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#A855F7" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0E0714" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                    Background="#1EA855F7" VerticalAlignment="Center">
                                <TextBlock Text="🧠" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                <TextBlock Text="Adaptive" Foreground="#F0F4F8"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="Targets your weak spots — personalized training"
                                           Foreground="#8A9BAE" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#4A5A6A"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#A855F7"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#A855F7"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#A855F7"/>
                                    <Ellipse Width="10" Height="10" Margin="2,0" Fill="#131B24"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- WARM-UP — #00C853, special routine -->
                    <Border x:Name="ScenarioBtn_WarmUp"
                            Tag="WarmUp"
                            CornerRadius="12" Margin="0,0,0,16"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00C853" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#07130A" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                    Background="#1E00C853" VerticalAlignment="Center">
                                <TextBlock Text="☀️" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="Daily Warm-Up" Foreground="#F0F4F8"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="4 × 60s guided routine"
                                           Foreground="#8A9BAE" FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Variant -->
                    <TextBlock Text="VARIANT" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="VariantCombo" Margin="0 0 0 16"
                              SelectionChanged="VariantCombo_Changed">
                        <ComboBoxItem Content="Smooth" IsSelected="True"/>
                        <ComboBoxItem Content="Evasive"/>
                        <ComboBoxItem Content="Two-Track"/>
                    </ComboBox>

                    <!-- Difficulty -->
                    <TextBlock Text="DIFFICULTY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="DifficultyCombo" Margin="0 0 0 16"
                              SelectionChanged="DifficultyCombo_Changed">
                        <ComboBoxItem Content="Easy" Tag="Easy"/>
                        <ComboBoxItem Content="Medium" IsSelected="True" Tag="Medium"/>
                        <ComboBoxItem Content="Hard" Tag="Hard"/>
                        <ComboBoxItem Content="Nightmare" Tag="Nightmare"/>
                    </ComboBox>

                    <!-- Duration -->
                    <TextBlock Text="DURATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="DurationCombo" Margin="0 0 0 20"
                              SelectionChanged="DurationCombo_Changed">
                        <ComboBoxItem Content="30 seconds" Tag="30" IsSelected="True"/>
                        <ComboBoxItem Content="60 seconds" Tag="60"/>
                        <ComboBoxItem Content="2 minutes" Tag="120"/>
                        <ComboBoxItem Content="5 minutes" Tag="300"/>
                    </ComboBox>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0 0 0 16"/>

                    <!-- Live stats during drill -->
                    <TextBlock Text="LIVE STATS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 10"/>

                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hits" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveHitsText" Grid.Column="1"
                                   Foreground="LightGreen" FontSize="14" FontWeight="Bold" Text="0"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Misses" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveMissesText" Grid.Column="1"
                                   Foreground="OrangeRed" FontSize="14" FontWeight="Bold" Text="0"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Accuracy" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveAccuracyText" Grid.Column="1"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Text="--"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Reaction" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveReactionText" Grid.Column="1"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="Bold" Text="--"/>
                    </Grid>
                    <Grid Margin="0 0 0 20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Score" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveScoreText" Grid.Column="1"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="Black" Text="0"/>
                    </Grid>

                    <!-- Start/Stop -->
                    <Button x:Name="StartStopBtn"
                            Content="▶  Start Drill"
                            Click="StartStop_Click"
                            Height="40"
                            FontSize="14" FontWeight="Bold"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0 0 0 8"/>

                    <Button Content="View History"
                            Click="ViewHistory_Click"
                            Height="32"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"
                            Margin="0 0 0 8"/>

                    <Button Content="Close"
                            Click="Close_Click"
                            Height="32"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"/>

                    <Button x:Name="RecommendedDrillsBtn"
                            Content="Recommended Drills"
                            Margin="6"
                            Padding="10,4"
                            Click="RecommendedDrillsBtn_Click"/>


                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════ RIGHT PANEL: CANVAS -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top HUD bar -->
            <Border Grid.Row="0"
                    Background="#0D000000"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="0 0 0 1">
                <Grid Margin="20 0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ScenarioLabel"
                                   Text="Tracking"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0 0 16 0"/>
                        <TextBlock x:Name="DifficultyLabel"
                                   Text="Medium"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="12"/>
                        <TextBlock x:Name="WarmUpRoundText"
                                   Text=""
                                   Foreground="LightGreen"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="16 0 0 0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Timer -->
                    <TextBlock x:Name="TimerText"
                               Text="0:30"
                               FontSize="22" FontWeight="Black"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Streak -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="STREAK " Foreground="{DynamicResource MutedText}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StreakText"
                                   Text="0"
                                   Foreground="Gold"
                                   FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Canvas + onboarding hint wrapper -->
            <Grid Grid.Row="1">

                <!-- TASK-3D: Timer bar — 4px accent line draining at top of drill area -->
                <Border Height="4" VerticalAlignment="Top"
                        CornerRadius="0" Panel.ZIndex="10"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <SolidColorBrush Color="#0A0A0A" Opacity="0.8"/>
                    </Border.Background>
                    <Border x:Name="TimerBarFill"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentPrimary}"
                            CornerRadius="0"
                            Width="0"/>
                </Border>

                <!-- TASK-3A: Main drill canvas with grid background -->
                <Canvas x:Name="TargetCanvas"
                        Cursor="Cross"
                        MouseDown="Canvas_MouseDown"
                        ClipToBounds="True">
                    <Canvas.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,50,50" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#07090E">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,50,50"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#0AFFFFFF">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,50,1"/>
                                                <RectangleGeometry Rect="0,0,1,50"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Canvas.Background>
                    <!-- Subtle radial vignette — focus the center zone -->
                    <Canvas.OpacityMask>
                        <RadialGradientBrush RadiusX="0.75" RadiusY="0.75">
                            <GradientStop Color="White"    Offset="0"/>
                            <GradientStop Color="White"    Offset="0.7"/>
                            <GradientStop Color="#E0FFFFFF" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Canvas.OpacityMask>

                    <!-- Idle message -->
                    <StackPanel x:Name="IdleMessage"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="SELECT A SCENARIO AND PRESS START"
                                   Foreground="#3A3A3A"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="or press SPACE"
                                   Foreground="#2A2A2A"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0 8 0 0"/>
                    </StackPanel>
                </Canvas>

                <!-- TASK-3E: Crosshair overlay — separate Canvas so ClearTargets never removes it -->
                <Canvas IsHitTestVisible="False" Panel.ZIndex="5">
                    <!-- Ring -->
                    <Ellipse x:Name="CrosshairRing"
                             Width="14" Height="14"
                             Stroke="#B2FFFFFF" StrokeThickness="1"
                             Fill="Transparent"
                             IsHitTestVisible="False"/>
                    <!-- Top arm -->
                    <Rectangle x:Name="CrosshairTop"
                               Width="1.5" Height="6"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                    <!-- Bottom arm -->
                    <Rectangle x:Name="CrosshairBottom"
                               Width="1.5" Height="6"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                    <!-- Left arm -->
                    <Rectangle x:Name="CrosshairLeft"
                               Width="6" Height="1.5"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                    <!-- Right arm -->
                    <Rectangle x:Name="CrosshairRight"
                               Width="6" Height="1.5"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                </Canvas>

                <!-- TASK-3F: Live stats overlay — top-right corner during drill -->
                <StackPanel x:Name="LiveStatsOverlay"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            Panel.ZIndex="10"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="ACC  "
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#608A9BAE"/>
                        <TextBlock x:Name="CanvasAccText"
                                   Text="—"
                                   FontSize="12" FontWeight="Black"
                                   Foreground="#CC00E5A0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="STK  "
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#608A9BAE"/>
                        <TextBlock x:Name="CanvasStreakText"
                                   Text="—"
                                   FontSize="12" FontWeight="Black"
                                   Foreground="#CCF5C842"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="HIT  "
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#608A9BAE"/>
                        <TextBlock x:Name="CanvasHitsText"
                                   Text="—"
                                   FontSize="12" FontWeight="Black"
                                   Foreground="#CCF0F4F8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Onboarding hint — shown only during the first session -->
                <TextBlock x:Name="OnboardingHintText"
                           Text="Follow the target — click when your crosshair is on it."
                           Foreground="#AAFFFFFF"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0 0 0 16"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
