<Window x:Class="CleanAimTracker.Windows.UpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade"
        Height="520"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0D0D"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="#141414"
            CornerRadius="14"
            Padding="28,24"
            BorderBrush="#2A2A2A"
            BorderThickness="1">

        <StackPanel>

            <!-- Lock icon + headline -->
            <TextBlock Text="🔒"
                       FontSize="32"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="FeatureHeadline"
                       Text="Unlock Pro Features"
                       FontSize="22"
                       FontWeight="Black"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,6"
                       TextWrapping="Wrap"/>

            <TextBlock Text="You've hit the free limit. Upgrade to keep improving."
                       Foreground="#666666"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <!-- Pro plan card -->
            <Border Background="#1A1A1A"
                    CornerRadius="10"
                    Padding="16,14"
                    Margin="0,0,0,10"
                    BorderBrush="#7B2FFF"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Pro Monthly" Foreground="White"
                                   FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Full history  •  AI coaching  •  Export"
                                   Foreground="#888888" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="$4.99" Foreground="#7B2FFF"
                                   FontSize="20" FontWeight="Black" HorizontalAlignment="Right"/>
                        <TextBlock Text="/month" Foreground="#555555"
                                   FontSize="11" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lifetime card -->
            <Border Background="#1A1A1A"
                    CornerRadius="10"
                    Padding="16,14"
                    Margin="0,0,0,20"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Lifetime" Foreground="White"
                                       FontSize="16" FontWeight="Bold"/>
                            <Border Background="#7B2FFF" CornerRadius="4"
                                    Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="BEST VALUE" Foreground="White"
                                           FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Everything forever  •  Pays off in 5 months"
                                   Foreground="#888888" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="$24.99" Foreground="White"
                                   FontSize="20" FontWeight="Black" HorizontalAlignment="Right"/>
                        <TextBlock Text="one-time" Foreground="#555555"
                                   FontSize="11" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Upgrade button -->
            <Button Content="Upgrade Now"
                    Click="Upgrade_Click"
                    FontSize="15"
                    FontWeight="Bold"
                    Height="48"
                    Margin="0,0,0,8"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#7B2FFF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#9B4FFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Dismiss -->
            <Button Content="Maybe later"
                    Click="Close_Click"
                    Background="Transparent"
                    Foreground="#444444"
                    BorderThickness="0"
                    FontSize="12"
                    Cursor="Hand"
                    Padding="6"/>

        </StackPanel>
    </Border>
</Window>
