<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Light Theme for Clean Aim Tracker ═══ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground"      Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CardBackground"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundAlt"   Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BannerBackground"    Color="#E3F2FD"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryText"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SecondaryText"       Color="#555555"/>
    <SolidColorBrush x:Key="MutedText"           Color="#999999"/>
    <SolidColorBrush x:Key="LabelText"           Color="#666666"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#0088AA"/>
    <SolidColorBrush x:Key="AccentDark"          Color="#006688"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#E65100"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="#2E7D32"/>
    <SolidColorBrush x:Key="GoldBrush"           Color="#F9A825"/>

    <!-- Input controls -->
    <SolidColorBrush x:Key="InputBackground"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorder"         Color="#CCCCCC"/>
    <SolidColorBrush x:Key="InputText"           Color="#1A1A1A"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonPrimaryBg"     Color="#0088AA"/>
    <SolidColorBrush x:Key="ButtonPrimaryFg"     Color="White"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg"   Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ButtonSecondaryFg"   Color="#333333"/>
    <SolidColorBrush x:Key="ButtonDangerBg"      Color="#D32F2F"/>
    <SolidColorBrush x:Key="ButtonDangerFg"      Color="White"/>

    <!-- Scrollbar / borders -->
    <SolidColorBrush x:Key="BorderBrush"         Color="#DDDDDD"/>
    <SolidColorBrush x:Key="SeparatorBrush"      Color="#E8E8E8"/>

</ResourceDictionary>
