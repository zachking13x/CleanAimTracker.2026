<Window x:Class="CleanAimTracker.Windows.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Summary"
        Width="520"
        Height="720"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="Session Summary"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <!-- Core Stats -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Core Stats"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TimeText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="DistanceText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="AvgSpeedText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="PeakSpeedText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Flicks -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Flicks"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="FlicksText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="SmallFlicksText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="LargeFlicksText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Diagnostics -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Diagnostics"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="SmoothnessText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="SharpnessText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="ConsistencyText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="QualityText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Advanced Diagnostics -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Advanced Metrics"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="CorrectionSharpnessText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="VelocityStabilityText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="IdlePenaltyText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="OverallDiagnosticText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Trend -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Trend Analysis"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TrendText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Close -->
            <Button Content="Close"
                    Click="Close_Click"
                    Style="{StaticResource GlowButton}"
                    HorizontalAlignment="Center"
                    Width="120"
                    Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
