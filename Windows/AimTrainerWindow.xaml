<Window x:Class="CleanAimTracker.Windows.AimTrainerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aim Trainer — Clean Aim Tracker"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <!-- Dark ComboBox for VARIANT / DIFFICULTY / DURATION -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"  Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <!-- Selected-item display -->
                            <Border Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <ContentPresenter Grid.Column="0"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{Binding SelectionBoxItem,
                                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- Drop arrow toggle -->
                            <ToggleButton Grid.Column="1"
                                          Focusable="False" ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen,
                                                      RelativeSource={RelativeSource TemplatedParent},
                                                      Mode=TwoWay}">
                                <Path Data="M 0 0 L 5 5 L 10 0"
                                      Stroke="{DynamicResource MutedText}"
                                      StrokeThickness="1.5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </ToggleButton>
                            <!-- Popup -->
                            <Popup Grid.ColumnSpan="2"
                                   x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="#444"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Padding"    Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ LEFT PANEL -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0 0 1 0">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <StackPanel Margin="16">

                    <!-- Logo / Title -->
                    <TextBlock Text="AIM TRAINER"
                               FontSize="18" FontWeight="Black"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0 16 0 4"/>
                    <TextBlock Text="Clean Aim Tracker"
                               FontSize="10"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0 0 0 20"/>

                    <!-- ══════════════════════════════════════════ SCENARIOS -->
                    <!-- Pillar: CLICKING -->
                    <Border x:Name="PillarHeader_Clicking"
                            CornerRadius="6" Padding="8 5" Margin="0 0 0 4"
                            Background="#0DFFB347" Cursor="Hand"
                            MouseDown="PillarHeader_Click">
                        <Grid>
                            <TextBlock Text="● CLICKING" FontSize="9" FontWeight="Bold"
                                       Foreground="#FFB347" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PillarArrow_Clicking"
                                       Text="▲" FontSize="9" Foreground="#FFB347"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel x:Name="PillarContent_Clicking">

                    <!-- StaticClicking — compact card -->
                    <Border x:Name="ScenarioBtn_StaticClicking"
                            Tag="StaticClicking" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FFB347" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#100D07" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Static Clicking" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="6 stationary targets · first-shot accuracy" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- DynamicClicking — compact card -->
                    <Border x:Name="ScenarioBtn_DynamicClicking"
                            Tag="DynamicClicking" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF8000" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#100900" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Dynamic Clicking" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Single moving target · click timing" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- Reactive — compact card -->
                    <Border x:Name="ScenarioBtn_Reactive"
                            Tag="Reactive" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF4545" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#100707" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Reactive" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Flashing targets · pure reflex speed" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- FLICKING — #FFB347, difficulty 3/4 -->
                    <Border x:Name="ScenarioBtn_Flicking"
                            Tag="Flicking"
                            CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FFB347" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#100D07" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Flicking" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Snap to new targets — reaction speed" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- PRECISION — #00E5A0, difficulty 2/4 -->
                    <Border x:Name="ScenarioBtn_Precision"
                            Tag="Precision"
                            CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00E5A0" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#071410" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Precision" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Small static targets — micro-adjustment" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SNIPER — #00E5A0 -->
                    <Border x:Name="ScenarioBtn_Sniper"
                            Tag="Sniper"
                            CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00E5A0" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#071410" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔭" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Sniper" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Long-range patience and precision" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SHOTGUN — #FF6B35 -->
                    <Border x:Name="ScenarioBtn_Shotgun"
                            Tag="Shotgun"
                            CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF6B35" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#100906" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💥" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Shotgun" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Close-range commitment and timing" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SMG/AR — #00D4FF -->
                    <Border x:Name="ScenarioBtn_SmgAr"
                            Tag="SmgAr"
                            CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00D4FF" BorderThickness="3,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#070F14" Offset="0"/>
                                <GradientStop Color="#0D1117" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🎮" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="SMG / AR" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Spray control and sustained movement" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    </StackPanel><!-- /PillarContent_Clicking -->

                    <!-- Pillar: TRACKING -->
                    <Border x:Name="PillarHeader_Tracking"
                            CornerRadius="6" Padding="8 5" Margin="0 6 0 4"
                            Background="#0D00D4FF" Cursor="Hand"
                            MouseDown="PillarHeader_Click">
                        <Grid>
                            <TextBlock Text="● TRACKING" FontSize="9" FontWeight="Bold"
                                       Foreground="#00D4FF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PillarArrow_Tracking"
                                       Text="▲" FontSize="9" Foreground="#00D4FF"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel x:Name="PillarContent_Tracking">

                    <!-- Compact Tracking card -->
                    <Border x:Name="ScenarioBtn_Tracking"
                            Tag="Tracking" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00D4FF" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#070F14" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👁️" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Tracking" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Follow moving targets — fluid mouse control" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- AirTracking compact card -->
                    <Border x:Name="ScenarioBtn_AirTracking"
                            Tag="AirTracking" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00BFFF" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#05101A" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Air Tracking" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Diagonal, arc, jetpack paths · axis balance" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    </StackPanel><!-- /PillarContent_Tracking -->

                    <!-- ── Pillar: SWITCHING ─────────────────────── -->
                    <Border x:Name="PillarHeader_Switching"
                            CornerRadius="6" Padding="8 5" Margin="0 6 0 4"
                            Background="#0DFF6B35" Cursor="Hand"
                            MouseDown="PillarHeader_Click">
                        <Grid>
                            <TextBlock Text="● SWITCHING" FontSize="9" FontWeight="Bold"
                                       Foreground="#FF6B35" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PillarArrow_Switching"
                                       Text="▲" FontSize="9" Foreground="#FF6B35"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel x:Name="PillarContent_Switching">

                    <!-- Switching compact card -->
                    <Border x:Name="ScenarioBtn_Switching"
                            Tag="Switching" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF6B35" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#100906" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔀" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Switching" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Multi-target speed · target acquisition" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SpeedSwitching compact card -->
                    <Border x:Name="ScenarioBtn_SpeedSwitching"
                            Tag="SpeedSwitching" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF5520" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#120700" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Speed Switching" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="High-density burst switching · routing" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- Evasive compact card -->
                    <Border x:Name="ScenarioBtn_Evasive"
                            Tag="Evasive" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#FF6B35" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#100906" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Evasive" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Target runs away · chase and corner" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- PeekTraining compact card -->
                    <Border x:Name="ScenarioBtn_PeekTraining"
                            Tag="PeekTraining" CornerRadius="8" Margin="0 0 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#E06050" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#100808" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <StackPanel Margin="12 8">
                            <TextBlock Text="Peek Training" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Fire in the peek window · timing" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                        </StackPanel>
                    </Border>

                    </StackPanel><!-- /PillarContent_Switching -->

                    <!-- ── SPECIAL ──────────────────────────────── -->
                    <!-- ADAPTIVE — #A855F7 -->
                    <Border x:Name="ScenarioBtn_Adaptive"
                            Tag="Adaptive" CornerRadius="8" Margin="0 6 0 3"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#A855F7" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0E0714" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🧠" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Adaptive" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Targets your weak spots — personalized" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- WARM-UP — #00C853 -->
                    <Border x:Name="ScenarioBtn_WarmUp"
                            Tag="WarmUp" CornerRadius="8" Margin="0 0 0 16"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            BorderBrush="#00C853" BorderThickness="3 0 0 0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#07130A" Offset="0"/>
                            <GradientStop Color="#0D1117" Offset="1"/>
                        </LinearGradientBrush></Border.Background>
                        <Grid Margin="12 9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="☀️" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4 0 0 0">
                                <TextBlock Text="Daily Warm-Up" Foreground="#F0F4F8" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="4 × 60s guided routine" Foreground="#8A9BAE" FontSize="9" Margin="0 1 0 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Variant -->
                    <TextBlock Text="VARIANT" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="VariantCombo" Margin="0 0 0 16"
                              SelectionChanged="VariantCombo_Changed">
                        <ComboBoxItem Content="Smooth" IsSelected="True"/>
                        <ComboBoxItem Content="Evasive"/>
                        <ComboBoxItem Content="Two-Track"/>
                    </ComboBox>

                    <!-- Difficulty — per-scenario button selector (TASK-23) -->
                    <TextBlock Text="DIFFICULTY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <UniformGrid Rows="1" Columns="4" Margin="0 0 0 16">
                        <Border x:Name="DiffBtn_Easy" Tag="Easy"
                                CornerRadius="6 0 0 6" Padding="4 6"
                                Cursor="Hand" MouseDown="DiffBtn_Click"
                                Background="#14FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
                            <TextBlock Text="Easy" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#60C878" HorizontalAlignment="Center"/>
                        </Border>
                        <Border x:Name="DiffBtn_Medium" Tag="Medium"
                                CornerRadius="0" Padding="4 6"
                                Cursor="Hand" MouseDown="DiffBtn_Click"
                                Background="#2200D4FF" BorderBrush="#4400D4FF" BorderThickness="1">
                            <TextBlock Text="Medium" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#00D4FF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border x:Name="DiffBtn_Hard" Tag="Hard"
                                CornerRadius="0" Padding="4 6"
                                Cursor="Hand" MouseDown="DiffBtn_Click"
                                Background="#14FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
                            <TextBlock Text="Hard" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FFB347" HorizontalAlignment="Center"/>
                        </Border>
                        <Border x:Name="DiffBtn_Nightmare" Tag="Nightmare"
                                CornerRadius="0 6 6 0" Padding="4 6"
                                Cursor="Hand" MouseDown="DiffBtn_Click"
                                Background="#14FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                                ToolTip="Reach 80%+ accuracy on Hard to unlock">
                            <TextBlock x:Name="NightmareBtnText"
                                       Text="🔒 NM" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#4A5A6A" HorizontalAlignment="Center"/>
                        </Border>
                    </UniformGrid>

                    <!-- Duration -->
                    <TextBlock Text="DURATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="DurationCombo" Margin="0 0 0 20"
                              SelectionChanged="DurationCombo_Changed">
                        <ComboBoxItem Content="30 seconds" Tag="30" IsSelected="True"/>
                        <ComboBoxItem Content="60 seconds" Tag="60"/>
                        <ComboBoxItem Content="2 minutes" Tag="120"/>
                        <ComboBoxItem Content="5 minutes" Tag="300"/>
                    </ComboBox>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0 0 0 16"/>

                    <!-- Live stats during drill -->
                    <TextBlock Text="LIVE STATS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 10"/>

                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hits" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveHitsText" Grid.Column="1"
                                   Foreground="LightGreen" FontSize="14" FontWeight="Bold" Text="0"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Misses" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveMissesText" Grid.Column="1"
                                   Foreground="OrangeRed" FontSize="14" FontWeight="Bold" Text="0"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Accuracy" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveAccuracyText" Grid.Column="1"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Text="--"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Reaction" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveReactionText" Grid.Column="1"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="Bold" Text="--"/>
                    </Grid>
                    <Grid Margin="0 0 0 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Score" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveScoreText" Grid.Column="1"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="Black" Text="0"/>
                    </Grid>

                    <!-- HOT STREAK BANNER — left panel, shown when 5 consecutive hits -->
                    <Border x:Name="HotStreakBanner"
                            Background="#1AFF6B35"
                            BorderBrush="#FF6B35"
                            BorderThickness="0,0,0,2"
                            CornerRadius="6"
                            Padding="10,7"
                            Margin="0,0,0,10"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔥 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="HOT STREAK — 2× SCORE"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#FF6B35"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Start/Stop -->
                    <Button x:Name="StartStopBtn"
                            Content="▶  Start Drill"
                            Click="StartStop_Click"
                            Height="40"
                            FontSize="14" FontWeight="Bold"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0 0 0 8"/>

                    <Button Content="View History"
                            Click="ViewHistory_Click"
                            Height="32"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"
                            Margin="0 0 0 8"/>

                    <Button Content="Close"
                            Click="Close_Click"
                            Height="32"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"/>

                    <Button x:Name="RecommendedDrillsBtn"
                            Content="Recommended Drills"
                            Margin="6"
                            Padding="10,4"
                            Click="RecommendedDrillsBtn_Click"/>


                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════ RIGHT PANEL: CANVAS -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top HUD bar -->
            <Border Grid.Row="0"
                    Background="#0D000000"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="0 0 0 1">
                <Grid Margin="20 0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ScenarioLabel"
                                   Text="Tracking"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0 0 16 0"/>
                        <TextBlock x:Name="DifficultyLabel"
                                   Text="Medium"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="12"/>
                        <TextBlock x:Name="WarmUpRoundText"
                                   Text=""
                                   Foreground="LightGreen"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="16 0 0 0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Timer -->
                    <TextBlock x:Name="TimerText"
                               Text="0:30"
                               FontSize="22" FontWeight="Black"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Streak -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="STREAK " Foreground="{DynamicResource MutedText}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StreakText"
                                   Text="0"
                                   Foreground="Gold"
                                   FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Canvas + onboarding hint wrapper -->
            <Grid Grid.Row="1">

                <!-- TASK-3D: Timer bar — 4px accent line draining at top of drill area -->
                <Border Height="4" VerticalAlignment="Top"
                        Background="{StaticResource BgElevated}"
                        CornerRadius="0" Panel.ZIndex="10"
                        IsHitTestVisible="False">
                    <Border x:Name="TimerBarFill"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Height="4"
                            Background="{StaticResource AccentPrimary}"
                            CornerRadius="0"
                            Width="0"/>
                </Border>

                <!-- TASK-3A: Main drill canvas with grid background -->
                <Canvas x:Name="TargetCanvas"
                        Cursor="Cross"
                        MouseDown="Canvas_MouseDown"
                        ClipToBounds="True">
                    <Canvas.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,50,50" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#07090E">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,50,50"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#0AFFFFFF">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,50,1"/>
                                                <RectangleGeometry Rect="0,0,1,50"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Canvas.Background>
                    <!-- Subtle radial vignette — focus the center zone -->
                    <Canvas.OpacityMask>
                        <RadialGradientBrush RadiusX="0.75" RadiusY="0.75">
                            <GradientStop Color="White"    Offset="0"/>
                            <GradientStop Color="White"    Offset="0.7"/>
                            <GradientStop Color="#E0FFFFFF" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Canvas.OpacityMask>

                    <!-- Idle message -->
                    <StackPanel x:Name="IdleMessage"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="SELECT A SCENARIO AND PRESS START"
                                   Foreground="#3A3A3A"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="or press SPACE"
                                   Foreground="#2A2A2A"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0 8 0 0"/>
                    </StackPanel>
                </Canvas>

                <!-- HOT STREAK — orange glow border over whole canvas area -->
                <Border x:Name="CanvasGlowBorder"
                        BorderBrush="#66FF6B35"
                        BorderThickness="3"
                        IsHitTestVisible="False"
                        Panel.ZIndex="15"
                        Visibility="Collapsed"/>

                <!-- TASK-3E: Crosshair overlay — separate Canvas so ClearTargets never removes it -->
                <Canvas IsHitTestVisible="False" Panel.ZIndex="5">
                    <!-- Ring -->
                    <Ellipse x:Name="CrosshairRing"
                             Width="14" Height="14"
                             Stroke="#B2FFFFFF" StrokeThickness="1"
                             Fill="Transparent"
                             IsHitTestVisible="False"/>
                    <!-- Top arm -->
                    <Rectangle x:Name="CrosshairTop"
                               Width="1.5" Height="6"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                    <!-- Bottom arm -->
                    <Rectangle x:Name="CrosshairBottom"
                               Width="1.5" Height="6"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                    <!-- Left arm -->
                    <Rectangle x:Name="CrosshairLeft"
                               Width="6" Height="1.5"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                    <!-- Right arm -->
                    <Rectangle x:Name="CrosshairRight"
                               Width="6" Height="1.5"
                               Fill="#B2FFFFFF"
                               IsHitTestVisible="False"/>
                </Canvas>

                <!-- TASK-3F: Live stats overlay — top-right corner during drill -->
                <StackPanel x:Name="LiveStatsOverlay"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            Panel.ZIndex="10"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="ACC  "
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#608A9BAE"/>
                        <TextBlock x:Name="CanvasAccText"
                                   Text="—"
                                   FontSize="12" FontWeight="Black"
                                   Foreground="#CC00E5A0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="HIT  "
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#608A9BAE"/>
                        <TextBlock x:Name="CanvasHitsText"
                                   Text="—"
                                   FontSize="12" FontWeight="Black"
                                   Foreground="#CCF0F4F8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Onboarding hint — shown only during the first session -->
                <TextBlock x:Name="OnboardingHintText"
                           Text="Follow the target — click when your crosshair is on it."
                           Foreground="#AAFFFFFF"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0 0 0 16"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>

                <!-- ── Drill Instruction Card (TASK-22) ─────────────────────── -->
                <!-- Shows TrainingFocus + MentalCue for the first 5 plays of    -->
                <!-- each scenario+variant, then auto-dismisses after 4 seconds. -->
                <Border x:Name="DrillInstructionCard"
                        Panel.ZIndex="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,20"
                        Visibility="Collapsed"
                        IsHitTestVisible="True"
                        CornerRadius="14"
                        Padding="28 22"
                        MaxWidth="420"
                        MouseDown="DrillInstructionCard_MouseDown">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#CC060912" Offset="0"/>
                            <GradientStop Color="#CC0A1020" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8000D4FF" Offset="0"/>
                            <GradientStop Color="#40A855F7" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1.5</Border.BorderThickness>
                    <Border.Effect>
                        <BlurEffect Radius="0"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Label chip -->
                        <Border Background="#2000D4FF" CornerRadius="4"
                                Padding="8 3" HorizontalAlignment="Left" Margin="0 0 0 10">
                            <TextBlock Text="DRILL FOCUS"
                                       FontSize="9" FontWeight="Bold" Foreground="#00D4FF"/>
                        </Border>

                        <!-- Focus title -->
                        <TextBlock x:Name="DrillFocusText"
                                   Text="Keep your crosshair ahead of the target"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#F0F4F8"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 8"/>

                        <!-- Mental cue -->
                        <Border Background="#15FFFFFF" CornerRadius="6"
                                Padding="10 7" Margin="0 0 0 14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬 " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DrillCueText"
                                           Text="Relax your grip — smooth wins over fast"
                                           FontSize="12"
                                           Foreground="#B0C4D8"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- 4-second countdown bar -->
                        <Grid>
                            <Border Background="#15FFFFFF" CornerRadius="3" Height="4"/>
                            <Border x:Name="DrillInstructionTimerBar"
                                    Background="#00D4FF" CornerRadius="3" Height="4"
                                    HorizontalAlignment="Left" Width="364"/>
                        </Grid>
                        <TextBlock x:Name="DrillInstructionTimerText"
                                   Text="Dismisses in 4s  ·  Click to dismiss"
                                   FontSize="9" Foreground="#4A6070"
                                   HorizontalAlignment="Center"
                                   Margin="0 5 0 0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
