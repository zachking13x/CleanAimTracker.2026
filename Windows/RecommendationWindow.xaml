<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Recommendation"
        Width="900"
        Height="660"
        MinWidth="820"
        MinHeight="560"
        Background="{StaticResource BgBase}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Icon="{StaticResource AppLogo}"
        x:Name="RootWindow">

    <Border Background="{StaticResource BgBase}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════ -->
            <!-- TITLE BAR                                  -->
            <!-- ══════════════════════════════════════════ -->
            <Grid Grid.Row="0"
                  Background="{StaticResource BgSurface}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="18" Height="18"
                        Margin="10,0,6,0"
                        VerticalAlignment="Center"
                        CornerRadius="3"
                        Background="{StaticResource AccentPrimary}">
                    <TextBlock Text="CA"
                               Foreground="Black"
                               FontSize="10" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="13"
                           Text="Sensitivity Recommendation"/>

                <Button Grid.Column="2"
                        Width="32" Height="24"
                        Margin="0,0,4,0"
                        Click="Minimize_Click"
                        Background="Transparent"
                        BorderThickness="0" Padding="0">
                    <TextBlock Text="–" HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="14"/>
                </Button>

                <Button Grid.Column="3"
                        Width="32" Height="24"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderThickness="0" Padding="0">
                    <TextBlock Text="✕" HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="12"/>
                </Button>
            </Grid>

            <!-- ══════════════════════════════════════════ -->
            <!-- CONTENT                                    -->
            <!-- ══════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER ROW: title + game picker -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="RECOMMENDED SETTINGS"
                                   Style="{StaticResource MetricLabelStyle}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Sensitivity Recommendation"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Game:"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="GameCombo"
                                  Width="200"
                                  ItemsSource="{Binding GameOptions, ElementName=RootWindow}"
                                  DisplayMemberPath="GameName"
                                  Background="{StaticResource BgSurface}"
                                  Foreground="{StaticResource TextPrimary}"
                                  BorderBrush="{StaticResource BorderSubtle}"
                                  Padding="8,4"
                                  SelectionChanged="GameCombo_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- MAIN SCROLL AREA -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ══════════════════════════════════
                             LEFT COLUMN
                        ══════════════════════════════════ -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">

                            <!-- HERO CARD — Recommended Sensitivity -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource CardBgCyan}"
                                    BorderBrush="{StaticResource AccentPrimary}"
                                    BorderThickness="0,2,0,0"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="RECOMMENDED SENSITIVITY"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <!-- 40px Black AccentPrimary — the dominant hero number -->
                                    <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4}}"
                                               FontSize="40" FontWeight="Black"
                                               Foreground="{StaticResource AccentPrimary}"
                                               Margin="0,4,0,4"
                                               SnapsToDevicePixels="True"/>
                                    <!-- Plain action line — the only instruction most users need -->
                                    <TextBlock Text="{Binding PlainActionLine, ElementName=RootWindow}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding RecommendedSensitivityRange, ElementName=RootWindow}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- DPI + YOUR SENSITIVITY row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- DPI -->
                                <Border Grid.Column="0"
                                        Style="{StaticResource MetricCardStyle}"
                                        Background="{StaticResource CardBgCyan}"
                                        BorderBrush="{StaticResource AccentPrimary}"
                                        BorderThickness="0,2,0,0">
                                    <StackPanel>
                                        <TextBlock Text="DPI"
                                                   Style="{StaticResource MetricLabelStyle}"/>
                                        <TextBlock Text="{Binding RecommendedDPI}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="{StaticResource AccentPrimary}"/>
                                        <TextBlock Text="{Binding DpiVerdict}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="10" FontStyle="Italic"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- YOUR SENSITIVITY + cm/360 -->
                                <Border Grid.Column="2"
                                        Style="{StaticResource MetricCardStyle}"
                                        Background="{StaticResource CardBgCyan}"
                                        BorderBrush="{StaticResource AccentPrimary}"
                                        BorderThickness="0,2,0,0">
                                    <StackPanel>
                                        <TextBlock Text="CM / 360"
                                                   Style="{StaticResource MetricLabelStyle}"/>
                                        <TextBlock Text="{Binding RecommendedCm360, StringFormat={}{0:F1}}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="{StaticResource AccentPrimary}"/>
                                        <TextBlock Text="{Binding Cm360PlainDesc, ElementName=RootWindow}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- CONFIDENCE CARD with progress bar -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource CardBgCyan}"
                                    BorderBrush="{StaticResource AccentPrimary}"
                                    BorderThickness="0,2,0,0"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <!-- Label + percentage -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="CONFIDENCE"
                                                   Style="{StaticResource MetricLabelStyle}"
                                                   Margin="0"/>
                                        <TextBlock Text="{Binding Confidence, StringFormat={}{0}%}"
                                                   Foreground="{StaticResource AccentPrimary}"
                                                   FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <!-- 6px progress bar — spec: AccentPrimary fill, BgElevated track -->
                                    <Border Height="6" CornerRadius="3"
                                            Background="{StaticResource BgElevated}">
                                        <Border Height="6" CornerRadius="3"
                                                Background="{StaticResource AccentPrimary}"
                                                RenderTransformOrigin="0,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding ConfidenceRatio, ElementName=RootWindow}"/>
                                            </Border.RenderTransform>
                                        </Border>
                                    </Border>
                                    <TextBlock Text="{Binding Confidence, StringFormat={}Based on {0}% data confidence}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- ANALYSIS + TIPS -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource BgSurface}"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="ANALYSIS"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding Explanation}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="12" Margin="0,4,0,12"/>

                                    <TextBlock Text="TIPS"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <ItemsControl ItemsSource="{Binding Tips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="→ "
                                                               Foreground="{StaticResource AccentPrimary}"
                                                               FontSize="11"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding ., Mode=OneWay}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ══════════════════════════════════
                             RIGHT COLUMN
                        ══════════════════════════════════ -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">

                            <!-- SETTINGS TO APPLY — styled label/value rows -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource BgSurface}"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="SETTINGS TO APPLY"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding GameSettingRows, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,6,0,6"
                                                        BorderThickness="0,0,0,1"
                                                        BorderBrush="{StaticResource BorderSubtle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   Foreground="{StaticResource AccentPrimary}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ADS / SCOPE — styled rows, hidden when empty -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource BgSurface}"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasAdsScopeSection, ElementName=RootWindow,
                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="ADS / SCOPE"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding AdsScopeRows, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,5,0,5"
                                                        BorderThickness="0,0,0,1"
                                                        BorderBrush="{StaticResource BorderSubtle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   Foreground="{StaticResource AccentPrimary}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ADVANCED — styled rows -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource BgSurface}"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="ADVANCED"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding AdvancedRows, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,5,0,5"
                                                        BorderThickness="0,0,0,1"
                                                        BorderBrush="{StaticResource BorderSubtle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   Foreground="{StaticResource AccentPrimary}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- TIPS FOR THIS GAME — arrow bullet list -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource BgSurface}"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="TIPS FOR THIS GAME"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding GameTipsLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="→ "
                                                               Foreground="{StaticResource AccentPrimary}"
                                                               FontSize="11"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding ., Mode=OneWay}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- CURRENT VS RECOMMENDED comparison -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource BgSurface}"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="CURRENT vs RECOMMENDED"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Current -->
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="CURRENT"
                                                       Style="{StaticResource MetricLabelStyle}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding CurrentDPI, StringFormat={}{0} DPI}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding CurrentSensitivity, StringFormat={}{0:F4} sens}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding CurrentCm360, StringFormat={}{0:F1} cm/360}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"/>
                                        </StackPanel>

                                        <!-- Recommended -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="RECOMMENDED"
                                                       Style="{StaticResource MetricLabelStyle}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding RecommendedDPI, StringFormat={}{0} DPI}"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4} sens}"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding RecommendedCm360, StringFormat={}{0:F1} cm/360}"
                                                       Foreground="{StaticResource AccentPrimary}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Overall verdict -->
                                    <Border Height="1"
                                            Background="{StaticResource BorderSubtle}"
                                            Margin="0,8,0,8"/>
                                    <TextBlock Text="{Binding OverallVerdict}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" FontStyle="Italic"/>
                                </StackPanel>
                            </Border>

                            <!-- ── TRANSITION PLAN CARD (TASK-25) ────────────────── -->
                            <!-- Shown at bottom of right column when active plan.  -->
                            <!-- Code-behind sets Visibility + populates text fields. -->
                            <Border x:Name="TransitionPlanCard"
                                Visibility="Collapsed"
                                Background="{StaticResource BgSurface}"
                                BorderBrush="#33A855F7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14 12"
                                Margin="8 8 0 0">
                            <StackPanel>
                                <!-- Header row -->
                                <Grid Margin="0 0 0 10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#20A855F7" CornerRadius="4"
                                                Padding="6 2" Margin="0 0 8 0">
                                            <TextBlock Text="📈 TRANSITION" FontSize="9"
                                                       FontWeight="Bold" Foreground="#A855F7"/>
                                        </Border>
                                        <TextBlock x:Name="TransitionTypeText"
                                                   Text="Gradual Plan" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TransitionProgressText"
                                               Text="Step 1 / 5"
                                               FontSize="10" Foreground="#A855F7"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Step progress bar -->
                                <Grid Margin="0 0 0 8">
                                    <Border Background="#15FFFFFF" CornerRadius="3" Height="5"/>
                                    <Border x:Name="TransitionProgressBar"
                                            Background="#A855F7" CornerRadius="3" Height="5"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Grid>

                                <!-- Current step target -->
                                <Grid Margin="0 0 0 6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Current step target"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TransitionCurrentTargetText"
                                               Grid.Column="1"
                                               Text="0.4500 sens  ·  28.3 cm/360"
                                               Foreground="#A855F7"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Sessions remaining -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sessions at this step"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TransitionSessionsText"
                                               Grid.Column="1"
                                               Text="1 / 3"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            </Border><!-- /TransitionPlanCard -->

                        </StackPanel><!-- /right column -->
                    </Grid>
                </ScrollViewer>

                <!-- FOOTER BUTTONS -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0">

                    <Button Content="Copy Settings"
                            Width="150"
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="CopySettings_Click"/>

                    <Button Content="Copy Comparison"
                            Width="150"
                            Margin="0,0,8,0"
                            Background="{StaticResource BgElevated}"
                            Foreground="{StaticResource TextPrimary}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtle}"
                            Click="CopyComparison_Click"/>

                    <Button Content="Close"
                            Width="100"
                            Background="{StaticResource BgElevated}"
                            Foreground="{StaticResource TextPrimary}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtle}"
                            Click="Close_Click"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
