<Window x:Class="CleanAimTracker.Windows.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Summary"
        Width="520"
        Height="820"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        Icon="{StaticResource AppLogo}"
        UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="Session Summary"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <!-- Recommended Settings -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,16">
                <StackPanel>

                    <TextBlock Text="Recommended Settings"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- Sensitivity -->
                    <TextBlock x:Name="RecommendedSensitivityText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="RecommendedSensitivityRangeText"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"/>

                    <!-- DPI -->
                    <TextBlock x:Name="RecommendedDpiText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,10,0,0"/>

                    <!-- cm/360 -->
                    <TextBlock x:Name="RecommendedCm360Text"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,10,0,0"/>

                    <TextBlock x:Name="RecommendedCm360RangeText"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"/>

                    <!-- cm/360 Explanation -->
                    <TextBlock Text="What is cm/360?"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"
                               Margin="0,12,0,0"/>

                    <TextBlock Text="cm/360 tells you how far you move your mouse to turn your character 360 degrees. Higher values give more control; lower values feel faster but harder to stabilize."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="RecommendedCm360WarningText"
                               Foreground="#FF6666"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,6,0,0"/>

                    <!-- Confidence -->
                    <TextBlock x:Name="ConfidenceText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,12,0,0"/>

                    <!-- Explanation -->
                    <TextBlock Text="Explanation"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"
                               Margin="0,12,0,0"/>

                    <TextBlock x:Name="ExplanationText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,4,0,0"/>

                    <!-- Tips -->
                    <TextBlock Text="Tips"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"
                               Margin="0,12,0,0"/>

                    <TextBlock x:Name="TipsText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,4,0,0"/>

                </StackPanel>
            </Border>

            <!-- Session Comparison -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12"
                    x:Name="ComparisonCard">
                <StackPanel>
                    <TextBlock Text="Your Progress"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0 0 0 10"/>

                    <TextBlock x:Name="QualityCompareText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13"
                               Margin="0 0 0 6"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="VelocityCompareText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13"
                               Margin="0 0 0 6"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="BaselineText"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Core Stats -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Core Stats"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TimeText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="DistanceText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="AvgSpeedText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="PeakSpeedText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Flicks -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Flicks"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="FlicksText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="SmallFlicksText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="LargeFlicksText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Diagnostics -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Diagnostics"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="SmoothnessText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="SharpnessText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="ConsistencyText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="QualityText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Advanced Diagnostics -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Advanced Metrics"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="CorrectionSharpnessText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Margin="0,4,0,0"/>

                    <TextBlock x:Name="VelocityStabilityText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="IdlePenaltyText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>

                    <TextBlock x:Name="OverallDiagnosticText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Trend -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Trend Analysis"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TrendText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- TASK-27: Personal best banner -->
            <Border x:Name="PersonalBestBanner"
                    Background="#0A4CAF50"
                    CornerRadius="10"
                    BorderBrush="#334CAF50"
                    BorderThickness="1"
                    Padding="16 14"
                    Margin="0 0 0 10"
                    Visibility="Collapsed">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0 0 140 0">
                        <TextBlock Text="🏆  New Personal Best!"
                                   Foreground="Gold"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0 0 0 4"/>
                        <TextBlock x:Name="PersonalBestScoreText"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Name="SharePbBtn"
                            Content="📋  Copy &amp; Share"
                            Click="SharePb_Click"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Height="34"
                            Width="130"
                            Background="#1A4CAF50"
                            Foreground="LightGreen"
                            FontSize="12"
                            FontWeight="Bold"
                            BorderThickness="1"
                            BorderBrush="#334CAF50"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- TASK-16: Streak retention message -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14,10"
                    Margin="0,0,0,10"
                    Visibility="Collapsed"
                    x:Name="StreakMessageBorder">
                <TextBlock x:Name="StreakMessageText"
                           Text=""
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </Border>

            <!-- TASK-18: Action buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Content="▶ Start Another"
                        Click="StartAnother_Click"
                        Style="{StaticResource GlowButton}"
                        Width="140"
                        Foreground="{DynamicResource AccentBrush}"
                        Margin="0,0,8,0"/>

                <Button Content="Close"
                        Click="Close_Click"
                        Style="{StaticResource GlowButton}"
                        Width="100"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
