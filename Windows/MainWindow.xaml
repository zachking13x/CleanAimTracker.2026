<Window x:Class="CleanAimTracker.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clean Aim Tracker"
        Height="720"
        Width="1200"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        Icon="{StaticResource AppLogo}"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>

        <!-- Stat card -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="12" ShadowDepth="0" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Label text -->
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedText}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0 0 0 2"/>
        </Style>

        <!-- Value text -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"
                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ToggleButton x:Name="PART_DropDownToggle" Grid.Column="1"
                                          Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Path Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource PrimaryText}"
                                      StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_DropDownToggle" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Glow Button -->
        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="12" ShadowDepth="0" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Nav Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder" Background="{TemplateBinding Background}" CornerRadius="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark tooltip — matches app theme -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#1C1C1C"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10 7">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="#CCCCCC"
                                       FontSize="12"
                                       MaxWidth="240"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ROOT: Sidebar + Main -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- LEFT SIDEBAR                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackground}"
                SnapsToDevicePixels="True">
            <DockPanel>

                <!-- TOP: Logo + App name -->
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,16">
                    <Image Source="{StaticResource AppLogo}" Width="36" Height="36"
                           HorizontalAlignment="Left" Stretch="Uniform" Margin="0 0 0 8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Clean Aim" Foreground="{DynamicResource PrimaryText}"
                                   FontSize="15" FontWeight="Bold" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="Tracker" Foreground="{DynamicResource AccentBrush}"
                               FontSize="15" FontWeight="Bold" Margin="0,-2,0,0"/>
                </StackPanel>

                <!-- BOTTOM: Theme toggle + Trial banner -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,12">

                    <!-- Trial Banner -->
                    <Border Background="{DynamicResource BannerBackground}"
                            CornerRadius="8" Padding="12,10"
                            Margin="0,0,0,8"
                            Cursor="Hand"
                            MouseDown="TrialBanner_Click">
                        <StackPanel>
                            <TextBlock x:Name="TrialBannerText"
                                       Text="Free Trial"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Tap to upgrade →"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme Toggle -->
                    <Button x:Name="ThemeToggleBtn"
                            Content="🌙  Dark Mode"
                            Click="ThemeToggle_Click"
                            Style="{StaticResource NavButtonStyle}"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- NAV BUTTONS -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="🏠  Home" Click="NavHome_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="NavHistoryBtn"
                            Content="📊  History" Click="NavHistory_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="AimTrainerNavBtn"
                            Content="🎯  Aim Trainer" Click="OpenAimTrainer_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{DynamicResource AccentBrush}"/>
                    <Button x:Name="NavLastReportBtn"
                            Content="🤖  Last Report" Click="ViewLastCoachReport_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="NavSensitivityBtn"
                            Content="🔄  Sensitivity" Click="OpenConverter_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📅  Weekly Report" Click="OpenWeeklyReport_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📤  Export Data" Click="OpenExport_Click" Style="{StaticResource NavButtonStyle}"/>

                    <!-- Thin separator -->
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="14,6"/>

                    <Button Content="⚙️  Settings" Click="NavSettings_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="ℹ️  About" Click="NavAbout_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="📖  Glossary" Click="OpenGlossary_Click" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Margin="14,12,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CONTROLS CARD -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="12"
                    Padding="20,14"
                    Margin="0,0,0,14"
                    SnapsToDevicePixels="True">
                <StackPanel>

                    <!-- Row 1: Inputs -->
                    <DockPanel Margin="0,0,0,10">
                        <!-- LastDeltaText on far right -->
                        <TextBlock x:Name="LastDeltaText"
                                   DockPanel.Dock="Right"
                                   Text="Last Delta: 0.0"
                                   Foreground="{DynamicResource SecondaryText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>

                        <!-- DPI -->
                        <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                            <TextBlock Text="DPI" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,0,0,3"
                                       ToolTip="Your mouse hardware DPI setting. Check your mouse software or physical DPI button. Common values: 400, 800, 1600, 3200."/>
                            <TextBox x:Name="DpiInput" Width="80" Text="800"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <!-- Sensitivity -->
                        <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                            <TextBlock Text="SENSITIVITY" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,0,0,3"
                                       ToolTip="Your in-game sensitivity value. Used to calculate cm/360 and generate sensitivity-specific coaching advice."/>
                            <TextBox x:Name="SensitivityInput" Width="80" Text="1.0"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <!-- Profile -->
                        <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                            <TextBlock Text="PROFILE" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="GameProfileCombo" Width="150" Height="30"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="GameProfileCombo_SelectionChanged"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Row 2: Buttons + Recording Indicator -->
                    <DockPanel>
                        <!-- Recording indicator (right) -->
                        <StackPanel x:Name="RecordingPanel"
                                    DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="12,0,0,0">
                            <Ellipse Width="8" Height="8" Fill="#EF5350" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="LIVE" Foreground="#EF5350" FontWeight="Bold"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="SessionTimeText" Text="00:00"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Action buttons (left) -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="StartButton" Content="▶  Start"
                                    Click="StartButton_Click"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="StopButton" Content="■  Stop"
                                    Click="StopButton_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="ResetButton" Content="↺  Reset"
                                    Click="ResetButton_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="SummaryButton" Content="Summary"
                                    Click="OpenSummary_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="RecommendButton" Content="Recommend"
                                    Click="OpenRecommendation_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"/>

                            <Button x:Name="ToggleOverlayButton" Content="👁  Overlay"
                                    Click="ToggleOverlay_Click"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </DockPanel>

                </StackPanel>
            </Border>

            <!-- STATS GRID (3 columns, 2 rows) -->
            <UniformGrid Grid.Row="1" Columns="3" Rows="2" SnapsToDevicePixels="True">

                <!-- ── Row 1, Col 1: Movement ── -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Movement" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="dX / dY" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Raw mouse delta — the X and Y axis movement your mouse reported each poll cycle."/>
                                <TextBlock x:Name="DxDyText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Total Distance" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Total raw mouse units moved this session. Higher means more physical mouse movement overall."/>
                                <TextBlock x:Name="TotalDistanceText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="cm/360" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Centimeters of physical desk movement for one full 360° spin in-game. Lower = faster/twitchier. Higher = slower/more precise. Most players prefer 20–50 cm/360."/>
                                <TextBlock x:Name="CmPer360Text" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Session Time" Style="{StaticResource LabelTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Verdict line — populated after session ends -->
                        <TextBlock x:Name="MovementVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 1, Col 2: Velocity ── -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Velocity" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Speed" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="SpeedText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="CurrentSpeedText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Peak" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="PeakSpeedText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Average" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="AverageSpeedText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MPS" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Mouse Movements Per Second — how actively your mouse was moving this session."/>
                                <TextBlock x:Name="MpsText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Rolling Density" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Micro-movements per second over the last 1-second window — indicates aim tremor or active micro-adjustment patterns."/>
                                <TextBlock x:Name="RollingDensityText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Peak Vel Change" Style="{StaticResource LabelTextStyle}"
                                       ToolTip="Largest sudden velocity change this session — high values mean fast, explosive flick shots."/>
                            <TextBlock x:Name="PeakVelocityChangeText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>

                        <!-- Verdict line -->
                        <TextBlock x:Name="VelocityVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 1, Col 3: Flicks ── -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Flicks" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Flicks" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="FlicksCountText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Small Flicks" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="SmallFlicksText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Large Flicks" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="LargeFlicksText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Idle Bursts" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Fast movements that start from near-stillness — indicates reactive, instinctive aim from a stationary position."/>
                                <TextBlock x:Name="IdleBurstsText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Row 2, Col 1: Aim Quality ── -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Aim Quality" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Overall Quality" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="Composite aim score 0–100 based on smoothness, control, and correction consistency. 70+ is solid; 85+ is elite."/>
                                <TextBlock x:Name="OverallQualityText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Smoothness" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="How fluid and continuous your movement is. High = fewer jerky direction changes. Aim for 65+."/>
                                <TextBlock x:Name="SmoothnessText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Correction Sharpness" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="How aggressively you correct your aim. Very high (80+) may mean you're overshooting targets; very low (&lt;20) may mean slow, hesitant adjustments."/>
                                <TextBlock x:Name="CorrectionSharpnessText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Stability" Style="{StaticResource LabelTextStyle}"
                                           ToolTip="How steady your aim is during slow movement or pauses. Higher is better for tracking scenarios."/>
                                <TextBlock x:Name="StabilityText" Text="--" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Verdict line -->
                        <TextBlock x:Name="QualityVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 2, Col 2: Advanced Metrics ── -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Advanced Metrics" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8"/>

                        <TextBlock Text="Angle Change" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="AngleChangeText" Text="--" Style="{StaticResource ValueTextStyle}"/>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <TextBlock Text="Jitter" Style="{StaticResource LabelTextStyle}"
                                   ToolTip="Rapid involuntary micro-movements that aren't intentional aim. High jitter can indicate grip tension, fatigue, or sensitivity set too high."/>
                        <TextBlock x:Name="JitterText" Text="--" Style="{StaticResource ValueTextStyle}"/>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <TextBlock Text="Movement Density" Style="{StaticResource LabelTextStyle}"
                                   ToolTip="Active movement events per second across the full session — how busy your aim is over time."/>
                        <TextBlock x:Name="DensityText" Text="--" Style="{StaticResource ValueTextStyle}"/>

                        <!-- Verdict line -->
                        <TextBlock x:Name="SmoothnessVerdictText" Text=""
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Row 2, Col 3: Today's Stats ── -->
                <Border x:Name="TodayStatsCard" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <!-- Header row with tier badge -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock Text="Today's Stats" Style="{StaticResource SectionHeaderText}"/>
                                <TextBlock Text=" 🔥" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Tier badge -->
                            <Border Grid.Column="1"
                                    x:Name="TierBadge"
                                    CornerRadius="6" Padding="8,3"
                                    Background="#1A1A1A">
                                <TextBlock x:Name="TierText"
                                           Text="Rookie"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#888888"/>
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SESSIONS TODAY" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="TodaySessionsText" Text="—" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel x:Name="StreakPanel" Grid.Column="1">
                                <TextBlock Text="CURRENT STREAK" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="StreakText" Text="—" Style="{StaticResource ValueTextStyle}"/>
                                <TextBlock Text="days in a row" Foreground="{DynamicResource MutedText}"
                                           FontSize="10" Margin="0,-8,0,8"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="BEST QUALITY" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="BestQualityTodayText" Text="—" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="WEEKLY AVG" Style="{StaticResource LabelTextStyle}"/>
                                <TextBlock x:Name="WeeklyAvgText" Text="—" Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ONBOARDING OVERLAY — 3s countdown, first session only   -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border x:Name="OnboardingOverlay"
                Grid.ColumnSpan="2"
                Background="#CC000000"
                Visibility="Collapsed"
                Panel.ZIndex="100">
            <Border Background="#0D0D1A"
                    BorderBrush="#2A2A4A"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="52 44"
                    MaxWidth="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="GET READY"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="11" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 18"/>

                    <TextBlock Text="Follow the target and click it when your crosshair is on it. We'll analyze your aim for 90 seconds and show you your results."
                               Foreground="White"
                               FontSize="16" FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="380"
                               Margin="0 0 0 32"/>

                    <!-- Countdown number -->
                    <TextBlock x:Name="OnboardingCountdownText"
                               Text="3"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="72" FontWeight="Black"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 28"/>

                    <!-- Got it button -->
                    <Button x:Name="OnboardingGotItBtn"
                            Content="Got it →"
                            Click="OnboardingGotIt_Click"
                            Height="44" Width="160"
                            HorizontalAlignment="Center"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- AIM TRAINER NAV HIGHLIGHT — shown after first session     -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="AimTrainerHighlight"
              Grid.ColumnSpan="2"
              Panel.ZIndex="99"
              Visibility="Collapsed"
              MouseDown="AimTrainerHighlight_Click"
              Cursor="Hand">

            <!-- Dim the rest of the window -->
            <Rectangle Fill="#99000000"/>

            <!-- Callout card — Margin set in code to align with nav button -->
            <Border x:Name="AimTrainerCallout"
                    Background="#0F1F0F"
                    BorderBrush="#3A7A3A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14 11"
                    MaxWidth="220"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Come back here to train anytime."
                               Foreground="LightGreen"
                               FontSize="12" FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Tap anywhere to dismiss"
                               Foreground="#555555"
                               FontSize="10"
                               Margin="0 5 0 0"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- GUIDED TOUR OVERLAY — runs once after first session      -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="TourOverlay"
              Grid.ColumnSpan="2"
              Panel.ZIndex="103"
              Visibility="Collapsed"
              MouseDown="TourOverlay_MouseDown">

            <!-- Full-screen dim -->
            <Rectangle Fill="#CC000000"/>

            <!-- Cyan highlight ring — size + position set in code per step -->
            <Border x:Name="TourHighlight"
                    BorderBrush="#00E5FF"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="#1000E5FF"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- Bubble card — positioned next to highlighted element -->
            <Border x:Name="TourBubble"
                    Background="#111111"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14 12"
                    MaxWidth="240"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    MouseDown="TourBubble_MouseDown">
                <StackPanel>
                    <TextBlock x:Name="TourBubbleText"
                               Foreground="White"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0 0 0 12"/>
                    <Button x:Name="TourNextBtn"
                            Content="Next →"
                            Click="TourNext_Click"
                            Height="28" Width="88"
                            HorizontalAlignment="Right"
                            FontSize="12" FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Final "You are set up" screen -->
            <Border x:Name="TourFinalCard"
                    Background="#0D0D1A"
                    BorderBrush="#1A1A3A"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="44 36"
                    MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    MouseDown="TourBubble_MouseDown">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="✓"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 16"/>
                    <TextBlock Text="You are set up."
                               Foreground="White"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 10"/>
                    <TextBlock Text="Come back daily for 5 minutes and your aim will improve. Your coach is already analyzing your data."
                               Foreground="#AAAAAA"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="360"
                               Margin="0 0 0 28"/>
                    <Button Content="Let's go"
                            Click="TourLetsGo_Click"
                            Height="42" Width="140"
                            HorizontalAlignment="Center"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>

    </Grid>

</Window>
