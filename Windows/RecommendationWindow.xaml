<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Recommendation"
        Width="520"
        Height="840"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="Recommended Settings"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <!-- Sensitivity -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Sensitivity"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4}}"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>

                    <TextBlock Text="{Binding SensitivityRangeText}"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- DPI -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="DPI"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding RecommendedDPI}"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- cm/360 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="cm/360 (Your Real Sensitivity)"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding RecommendedCm360, StringFormat={}{0:F2}}"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>

                    <TextBlock Text="{Binding Cm360Verdict}"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,2,0,0"/>

                    <TextBlock Text="What is cm/360?"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"
                               Margin="0,12,0,0"/>

                    <TextBlock Text="cm/360 tells you how far you move your mouse to turn your character 360 degrees. Higher values give more control; lower values feel faster but harder to stabilize."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Confidence -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Confidence"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding Confidence, StringFormat={}{0}%}"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Explanation -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Explanation"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding Explanation}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tips -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Tips"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ItemsControl ItemsSource="{Binding Tips}"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="0,4,0,0">
                                    <Run Text="• " />
                                    <Run Text="{Binding ., Mode=OneWay}" />
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Trend -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Trend Analysis"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding TrendSummary}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Comparison -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Current vs Recommended"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Current -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Current"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding CurrentDPI, StringFormat=DPI: {0}}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>

                            <TextBlock Text="{Binding CurrentSensitivity, StringFormat=Sens: {0:F4}}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>

                            <TextBlock Text="{Binding CurrentCm360, StringFormat=cm/360: {0:F2}}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Recommended -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Recommended"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding RecommendedDPI, StringFormat=DPI: {0}}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>

                            <TextBlock Text="{Binding RecommendedSensitivity, StringFormat=Sens: {0:F4}}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>

                            <TextBlock Text="{Binding RecommendedCm360, StringFormat=cm/360: {0:F2}}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Buttons Row -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">

                <Button Content="Copy Settings"
                        Width="150"
                        Margin="0,0,12,0"
                        Style="{StaticResource GlowButton}"
                        Click="CopySettings_Click"/>

                <Button Content="Copy Comparison"
                        Width="150"
                        Margin="0,0,12,0"
                        Style="{StaticResource GlowButton}"
                        Click="CopyComparison_Click"/>

                <Button Content="Close"
                        Width="150"
                        Style="{StaticResource GlowButton}"
                        Click="Close_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
