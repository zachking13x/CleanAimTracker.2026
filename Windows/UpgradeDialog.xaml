<Window x:Class="CleanAimTracker.Windows.UpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade to Pro"
        Height="260"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="12"
            Padding="20"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1">

        <StackPanel>

            <TextBlock Text="Upgrade Required"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"
                       Margin="0 0 0 12"/>

            <TextBlock Text="Your free trial has expired. Unlock all Pro features including:"
                       Foreground="{DynamicResource SecondaryText}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0 0 0 12"/>

            <StackPanel Margin="0 0 0 12">
                <TextBlock Text="• Aim Trainer" Foreground="{DynamicResource PrimaryText}"/>
                <TextBlock Text="• Session History" Foreground="{DynamicResource PrimaryText}"/>
                <TextBlock Text="• Recommendations" Foreground="{DynamicResource PrimaryText}"/>
                <TextBlock Text="• In‑Game Overlay" Foreground="{DynamicResource PrimaryText}"/>
            </StackPanel>

            <Button Content="Upgrade Now"
                    Click="Upgrade_Click"
                    Style="{StaticResource GlowButton}"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    Padding="10"
                    Margin="0 0 0 8"/>

            <Button Content="Close"
                    Click="Close_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource SecondaryText}"
                    BorderThickness="0"
                    Padding="6"/>

        </StackPanel>
    </Border>
</Window>
