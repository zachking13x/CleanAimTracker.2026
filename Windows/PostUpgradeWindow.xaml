<Window x:Class="CleanAimTracker.Windows.PostUpgradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Pro"
        Width="420" Height="490"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource AppBackground}"
            CornerRadius="14"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">
        <StackPanel Margin="36 32">

            <TextBlock Text="🎉" FontSize="52"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 6"/>

            <TextBlock Text="You're Pro!"
                       FontSize="28" FontWeight="Black"
                       Foreground="LightGreen"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 4"/>

            <TextBlock Text="All features are now unlocked."
                       FontSize="13"
                       Foreground="{DynamicResource MutedText}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 28"/>

            <!-- Unlocked features -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="10" Padding="20 14" Margin="0 0 0 28">
                <StackPanel>
                    <TextBlock Text="UNLOCKED"
                               Foreground="{DynamicResource MutedText}"
                               FontSize="10" FontWeight="Bold"
                               Margin="0 0 0 12"/>
                    <TextBlock Text="✅  Aim Trainer — all scenarios &amp; difficulties"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  Full session history &amp; AI coaching reports"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  Weekly performance reports"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  In-game live stats overlay"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13" Margin="0 0 0 7"/>
                    <TextBlock Text="✅  Data export &amp; unlimited profiles"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Let's Go button -->
            <Button Content="Let's Go  →"
                    Click="LetsGo_Click"
                    Height="46"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Black"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#66BB6A"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</Window>
