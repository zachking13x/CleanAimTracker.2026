<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Recommendation"
        Width="900"
        Height="650"
        MinWidth="800"
        MinHeight="550"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource AppBackground}"
            CornerRadius="8"
            BorderBrush="#33000000"
            BorderThickness="1">
        <Grid>

            <Grid.RowDefinitions>
                <!-- Custom title bar -->
                <RowDefinition Height="40"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  Background="#22252A"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Simple branded mark instead of external icon resource -->
                <Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        Margin="10,0,6,0"
                        VerticalAlignment="Center"
                        CornerRadius="3"
                        Background="#00AFFF">
                    <TextBlock Text="CA"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="13"
                           Text="Sensitivity Recommendation" />

                <!-- Minimize -->
                <Button Grid.Column="2"
                        Width="32"
                        Height="24"
                        Margin="0,0,4,0"
                        Click="Minimize_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <TextBlock Text="–"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </Button>

                <!-- Close -->
                <Button Grid.Column="3"
                        Width="32"
                        Height="24"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <TextBlock Text="✕"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="12"/>
                </Button>
            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="16,10,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top row: header + game selector -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Recommended Settings"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Game:"
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox Width="200"
                                  ItemsSource="{Binding GameOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding Path=SelectedGame, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                  DisplayMemberPath="GameName"
                                  Background="{DynamicResource CardBackground}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  BorderBrush="#444"
                                  Padding="4,2"/>
                    </StackPanel>
                </Grid>

                <!-- MAIN TWO-COLUMN AREA -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: core recommendation cards -->
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">

                            <!-- Sensitivity -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Sensitivity"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4}}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>

                                    <TextBlock Text="{Binding SensitivityRangeText}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="12"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- DPI -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="DPI"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding RecommendedDPI}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- cm/360 -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="cm/360 (Your Real Sensitivity)"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding RecommendedCm360, StringFormat={}{0:F2}}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>

                                    <TextBlock Text="{Binding Cm360Verdict}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="12"
                                               Margin="0,2,0,0"/>

                                    <TextBlock Text="What is cm/360?"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontWeight="Bold"
                                               Margin="0,12,0,0"/>

                                    <TextBlock Text="cm/360 tells you how far you move your mouse to turn your character 360 degrees. Higher values give more control; lower values feel faster but harder to stabilize."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Confidence -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Confidence"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Confidence, StringFormat={}{0}%}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Explanation -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Explanation"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Explanation}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="13"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Tips -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Tips"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding Tips}"
                                                  Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           Margin="0,4,0,0">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding ., Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Trend -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Trend Analysis"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding TrendSummary}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="13"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Comparison -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Current vs Recommended"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Current -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Current"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,6"/>

                                            <TextBlock Text="{Binding CurrentDPI, StringFormat=DPI: {0}}"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,2,0,0"/>

                                            <TextBlock Text="{Binding CurrentSensitivity, StringFormat=Sens: {0:F4}}"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,2,0,0"/>

                                            <TextBlock Text="{Binding CurrentCm360, StringFormat=cm/360: {0:F2}}"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Recommended -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Recommended"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,6"/>

                                            <TextBlock Text="{Binding RecommendedDPI, StringFormat=DPI: {0}}"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,2,0,0"/>

                                            <TextBlock Text="{Binding RecommendedSensitivity, StringFormat=Sens: {0:F4}}"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,2,0,0"/>

                                            <TextBlock Text="{Binding RecommendedCm360, StringFormat=cm/360: {0:F2}}"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- RIGHT COLUMN: game-specific cards -->
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">

                            <!-- Game Settings to Apply -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold">
                                        <Run Text="{Binding Path=SelectedGame.GameName, 
                                                            RelativeSource={RelativeSource AncestorType=Window}, 
                                                            Mode=OneWay}" />

                                        <Run Text=" Settings to Apply" />
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding GameSettingsLines, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           Margin="0,2,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ADS / Scope -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14"
                                    Visibility="{Binding HasAdsScopeSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="ADS / Scope Settings"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding AdsScopeLines, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           Margin="0,2,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Advanced Settings -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Advanced Settings"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding AdvancedLines, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           Margin="0,2,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Tips for This Game -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Tips for This Game"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <ItemsControl ItemsSource="{Binding GameTipsLines, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           Margin="0,4,0,0">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- BUTTONS ROW -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">

                    <Button Content="Copy Settings"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource GlowButton}"
                            Click="CopySettings_Click"/>

                    <Button Content="Copy Comparison"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource GlowButton}"
                            Click="CopyComparison_Click"/>

                    <Button Content="Close"
                            Width="150"
                            Style="{StaticResource GlowButton}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
