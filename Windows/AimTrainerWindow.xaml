<Window x:Class="CleanAimTracker.Windows.AimTrainerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aim Trainer — Clean Aim Tracker"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <!-- Dark ComboBox for VARIANT / DIFFICULTY / DURATION -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"  Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <!-- Selected-item display -->
                            <Border Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <ContentPresenter Grid.Column="0"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{Binding SelectionBoxItem,
                                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- Drop arrow toggle -->
                            <ToggleButton Grid.Column="1"
                                          Focusable="False" ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen,
                                                      RelativeSource={RelativeSource TemplatedParent},
                                                      Mode=TwoWay}">
                                <Path Data="M 0 0 L 5 5 L 10 0"
                                      Stroke="{DynamicResource MutedText}"
                                      StrokeThickness="1.5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </ToggleButton>
                            <!-- Popup -->
                            <Popup Grid.ColumnSpan="2"
                                   x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="#444"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Padding"    Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ LEFT PANEL -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackground}"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0 0 1 0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">

                    <!-- Logo / Title -->
                    <TextBlock Text="AIM TRAINER"
                               FontSize="18" FontWeight="Black"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0 16 0 4"/>
                    <TextBlock Text="Clean Aim Tracker"
                               FontSize="10"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0 0 0 20"/>

                    <!-- Scenario Selector -->
                    <TextBlock Text="SCENARIO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>

                    <!-- TRACKING — cyan, difficulty 2/4 -->
                    <Border x:Name="ScenarioBtn_Tracking"
                            Tag="Tracking"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,5"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            Background="#2200D4FF"
                            BorderBrush="#CC00D4FF" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="👁️" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Tracking" Foreground="White"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="Follow moving targets — builds fluid mouse control"
                                           Foreground="#7A8A99" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#7A8A99"
                                           HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#00D4FF"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#00D4FF"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#2A3A44"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#2A3A44"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- FLICKING — yellow/gold, difficulty 3/4 -->
                    <Border x:Name="ScenarioBtn_Flicking"
                            Tag="Flicking"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,5"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            Background="Transparent"
                            BorderBrush="#66FFD700" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚡" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Flicking" Foreground="White"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="Snap to new targets instantly — builds reaction speed"
                                           Foreground="#7A8A99" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#7A8A99"
                                           HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FFD700"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FFD700"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FFD700"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#2A3A44"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- PRECISION — green, difficulty 2/4 -->
                    <Border x:Name="ScenarioBtn_Precision"
                            Tag="Precision"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,5"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            Background="Transparent"
                            BorderBrush="#6600FF9D" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🎯" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Precision" Foreground="White"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="Click small static targets — builds micro-adjustment"
                                           Foreground="#7A8A99" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#7A8A99"
                                           HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#00FF9D"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#00FF9D"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#2A3A44"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#2A3A44"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SWITCHING — orange, difficulty 4/4 -->
                    <Border x:Name="ScenarioBtn_Switching"
                            Tag="Switching"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,5"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            Background="Transparent"
                            BorderBrush="#66FF6B35" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔀" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Switching" Foreground="White"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="Multi-target speed — builds target acquisition"
                                           Foreground="#7A8A99" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#7A8A99"
                                           HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FF6B35"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FF6B35"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FF6B35"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#FF6B35"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ADAPTIVE — purple, difficulty 3/4 -->
                    <Border x:Name="ScenarioBtn_Adaptive"
                            Tag="Adaptive"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,5"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            Background="Transparent"
                            BorderBrush="#669B59B6" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🧠" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Adaptive" Foreground="{DynamicResource AccentBrush}"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="Targets your weak spots — personalized training"
                                           Foreground="#7A8A99" FontSize="10" TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="SKILL" FontSize="7" Foreground="#7A8A99"
                                           HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#9B59B6"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#9B59B6"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#9B59B6"/>
                                    <Ellipse Width="7" Height="7" Margin="2,0" Fill="#2A3A44"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- WARM-UP — green, special routine -->
                    <Border x:Name="ScenarioBtn_WarmUp"
                            Tag="WarmUp"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,16"
                            Cursor="Hand" MouseDown="ScenarioBtn_Click"
                            Background="Transparent"
                            BorderBrush="#3300C853" BorderThickness="1.5">
                        <StackPanel>
                            <TextBlock Text="☀️  Daily Warm-Up" Foreground="LightGreen"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="4 × 60s guided routine" Foreground="#888"
                                       FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Variant -->
                    <TextBlock Text="VARIANT" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="VariantCombo" Margin="0 0 0 16"
                              SelectionChanged="VariantCombo_Changed">
                        <ComboBoxItem Content="Smooth" IsSelected="True"/>
                        <ComboBoxItem Content="Evasive"/>
                        <ComboBoxItem Content="Two-Track"/>
                    </ComboBox>

                    <!-- Difficulty -->
                    <TextBlock Text="DIFFICULTY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="DifficultyCombo" Margin="0 0 0 16"
                              SelectionChanged="DifficultyCombo_Changed">
                        <ComboBoxItem Content="Easy" Tag="Easy"/>
                        <ComboBoxItem Content="Medium" IsSelected="True" Tag="Medium"/>
                        <ComboBoxItem Content="Hard" Tag="Hard"/>
                        <ComboBoxItem Content="Nightmare" Tag="Nightmare"/>
                    </ComboBox>

                    <!-- Duration -->
                    <TextBlock Text="DURATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 8"/>
                    <ComboBox x:Name="DurationCombo" Margin="0 0 0 20"
                              SelectionChanged="DurationCombo_Changed">
                        <ComboBoxItem Content="30 seconds" Tag="30" IsSelected="True"/>
                        <ComboBoxItem Content="60 seconds" Tag="60"/>
                        <ComboBoxItem Content="2 minutes" Tag="120"/>
                        <ComboBoxItem Content="5 minutes" Tag="300"/>
                    </ComboBox>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0 0 0 16"/>

                    <!-- Live stats during drill -->
                    <TextBlock Text="LIVE STATS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedText}" Margin="0 0 0 10"/>

                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hits" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveHitsText" Grid.Column="1"
                                   Foreground="LightGreen" FontSize="14" FontWeight="Bold" Text="0"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Misses" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveMissesText" Grid.Column="1"
                                   Foreground="OrangeRed" FontSize="14" FontWeight="Bold" Text="0"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Accuracy" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveAccuracyText" Grid.Column="1"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Text="--"/>
                    </Grid>
                    <Grid Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Reaction" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveReactionText" Grid.Column="1"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="Bold" Text="--"/>
                    </Grid>
                    <Grid Margin="0 0 0 20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Score" Foreground="{DynamicResource LabelText}" FontSize="12"/>
                        <TextBlock x:Name="LiveScoreText" Grid.Column="1"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="Black" Text="0"/>
                    </Grid>

                    <!-- Start/Stop -->
                    <Button x:Name="StartStopBtn"
                            Content="▶  Start Drill"
                            Click="StartStop_Click"
                            Height="40"
                            FontSize="14" FontWeight="Bold"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0 0 0 8"/>

                    <Button Content="View History"
                            Click="ViewHistory_Click"
                            Height="32"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"
                            Margin="0 0 0 8"/>

                    <Button Content="Close"
                            Click="Close_Click"
                            Height="32"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"/>

                    <Button x:Name="RecommendedDrillsBtn"
                            Content="Recommended Drills"
                            Margin="6"
                            Padding="10,4"
                            Click="RecommendedDrillsBtn_Click"/>


                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════ RIGHT PANEL: CANVAS -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top HUD bar -->
            <Border Grid.Row="0"
                    Background="#0D000000"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="0 0 0 1">
                <Grid Margin="20 0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ScenarioLabel"
                                   Text="Tracking"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0 0 16 0"/>
                        <TextBlock x:Name="DifficultyLabel"
                                   Text="Medium"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="12"/>
                        <TextBlock x:Name="WarmUpRoundText"
                                   Text=""
                                   Foreground="LightGreen"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="16 0 0 0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Timer -->
                    <TextBlock x:Name="TimerText"
                               Text="0:30"
                               FontSize="22" FontWeight="Black"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Streak -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="STREAK " Foreground="{DynamicResource MutedText}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StreakText"
                                   Text="0"
                                   Foreground="Gold"
                                   FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Canvas + onboarding hint wrapper -->
            <Grid Grid.Row="1">
                <Canvas x:Name="TargetCanvas"
                        Background="#0A0A0A"
                        Cursor="Cross"
                        MouseDown="Canvas_MouseDown"
                        ClipToBounds="True">

                    <!-- Crosshair dot -->
                    <Ellipse x:Name="CenterDot"
                             Width="6" Height="6"
                             Fill="#44FFFFFF"
                             IsHitTestVisible="False"/>

                    <!-- Idle message -->
                    <StackPanel x:Name="IdleMessage"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="SELECT A SCENARIO AND PRESS START"
                                   Foreground="#333"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="or press SPACE"
                                   Foreground="#222"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0 8 0 0"/>
                    </StackPanel>

                </Canvas>

                <!-- Onboarding hint — shown only during the first session -->
                <TextBlock x:Name="OnboardingHintText"
                           Text="Follow the target — click when your crosshair is on it."
                           Foreground="#AAFFFFFF"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0 0 0 16"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
