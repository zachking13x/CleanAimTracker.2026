<Window x:Class="CleanAimTracker.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420"
        Height="520"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        Icon="{StaticResource AppLogo}"
        UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="Settings"
                       Foreground="{DynamicResource PrimaryText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- DPI -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Default DPI"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="DpiInput"
                             Height="32"
                             Margin="0,8,0,0"
                             FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Sensitivity -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Default Sensitivity"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="SensitivityInput"
                             Height="32"
                             Margin="0,8,0,0"
                             FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Theme -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Theme"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="ThemeSelector"
                              Height="32"
                              Margin="0,8,0,0"
                              FontSize="14">
                        <ComboBoxItem Content="Dark" />
                        <ComboBoxItem Content="Light" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Content="Save Settings"
                    Height="40"
                    Margin="0,20,0,0"
                    Style="{StaticResource GlowButton}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>
