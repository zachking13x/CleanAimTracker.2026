<Window x:Class="CleanAimTracker.Windows.AimTrainerResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aim Trainer Results"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource CardBackground}"
        Width="420" Height="520"
        AllowsTransparency="True">

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="12"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            Padding="20">

        <StackPanel>

            <!-- Header -->
            <TextBlock Text="RESULTS"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Scenario -->
            <TextBlock Text="{Binding Scenario}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"/>

            <!-- Difficulty -->
            <TextBlock Text="{Binding Difficulty}"
                       FontSize="12"
                       Foreground="{DynamicResource MutedText}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Stats Grid -->
            <Grid Margin="0 10 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Hits -->
                <StackPanel Grid.Column="0" Margin="0 0 10 0">
                    <TextBlock Text="Hits" Foreground="{DynamicResource MutedText}" />
                    <TextBlock Text="{Binding Hits}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}" />
                </StackPanel>

                <!-- Misses -->
                <StackPanel Grid.Column="1" Margin="10 0 0 0">
                    <TextBlock Text="Misses" Foreground="{DynamicResource MutedText}" />
                    <TextBlock Text="{Binding Misses}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}" />
                </StackPanel>
            </Grid>

            <!-- Accuracy -->
            <StackPanel Margin="0 0 0 20">
                <TextBlock Text="Accuracy" Foreground="{DynamicResource MutedText}" />
                <TextBlock Text="{Binding Accuracy, StringFormat={}{0:F1}%}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}" />
            </StackPanel>

            <!-- Reaction Times -->
            <StackPanel Margin="0 0 0 20">
                <TextBlock Text="Avg Reaction" Foreground="{DynamicResource MutedText}" />
                <TextBlock Text="{Binding AvgReactionMs, StringFormat={}{0:F0} ms}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}" />
            </StackPanel>

            <StackPanel Margin="0 0 0 20">
                <TextBlock Text="Best Reaction" Foreground="{DynamicResource MutedText}" />
                <TextBlock Text="{Binding BestReactionMs, StringFormat={}{0:F0} ms}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}" />
            </StackPanel>

            <!-- Score -->
            <StackPanel Margin="0 0 0 30">
                <TextBlock Text="Score" Foreground="{DynamicResource MutedText}" />
                <TextBlock Text="{Binding Score, StringFormat={}{0:N0}}"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" />
            </StackPanel>

            <!-- Close Button -->
            <Button Content="Close"
                    Width="120"
                    HorizontalAlignment="Center"
                    Padding="8 4"
                    Style="{StaticResource GlowButton}"
                    Click="Close_Click"/>

        </StackPanel>
    </Border>
</Window>
