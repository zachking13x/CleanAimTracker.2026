<Window x:Class="CleanAimTracker.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Clean Aim Tracker" Width="520" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        ResizeMode="NoResize">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App Title -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Clean Aim Tracker"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Text="Version 1.0.0"
                       FontSize="13" Foreground="{DynamicResource MutedText}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Description -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="ABOUT" Foreground="{DynamicResource MutedText}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryText}" FontSize="13"
                                   LineHeight="20">
                            Clean Aim Tracker is a mouse analytics tool for FPS gamers.
                            It captures raw mouse input to measure velocity, acceleration,
                            flick patterns, jitter, and movement quality in real time.
                            The built-in recommendation engine analyzes your movement data
                            and suggests DPI and sensitivity adjustments to improve your aim.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- How Profiles Work -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="SENSITIVITY PROFILES" Foreground="{DynamicResource MutedText}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PrimaryText}" FontSize="13"
                                   LineHeight="20">
                            Built-in presets use genre-based descriptors (e.g. "Tactical Shooter A")
                            paired with publicly measured yaw constants. These mathematical
                            constants describe how mouse input maps to in-game rotation and are
                            not copyrightable. You can create your own custom profiles with any
                            name and yaw value you choose.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Developer Info -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="DEVELOPER" Foreground="{DynamicResource MutedText}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Zach King" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Support: cleanaimtracker@outlook.com" Foreground="{DynamicResource SecondaryText}" FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock x:Name="PrivacyLink" Text="Privacy Policy: Coming Soon"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="13" Margin="0,4,0,0"
                                   Cursor="Hand" TextDecorations="Underline"/>
                    </StackPanel>
                </Border>

                <!-- Legal -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="LEGAL" Foreground="{DynamicResource MutedText}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryText}" FontSize="12"
                                   LineHeight="18">
                            This application is not affiliated with, endorsed by, or associated
                            with any game developer or publisher. All sensitivity calculations use
                            publicly available mathematical constants. Game names appearing in
                            user-created custom profiles are entered by the user and do not imply
                            any endorsement or affiliation.
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="2" Content="Close" Click="Close_Click"
                Background="{DynamicResource ButtonSecondaryBg}"
                Foreground="{DynamicResource ButtonSecondaryFg}"
                FontSize="14" Padding="24,8"
                HorizontalAlignment="Center" Margin="0,12,0,0"
                BorderThickness="0" Cursor="Hand"/>
    </Grid>
</Window>
