<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Dark Theme for Clean Aim Tracker ═══ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground"      Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardBackground"      Color="#2A2A2A"/>
    <SolidColorBrush x:Key="CardBackgroundAlt"   Color="#333333"/>
    <SolidColorBrush x:Key="BannerBackground"    Color="#1A3A4A"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryText"         Color="White"/>
    <SolidColorBrush x:Key="SecondaryText"       Color="LightGray"/>
    <SolidColorBrush x:Key="MutedText"           Color="#888888"/>
    <SolidColorBrush x:Key="LabelText"           Color="#AAAAAA"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#00D4FF"/>
    <SolidColorBrush x:Key="AccentDark"          Color="#0099BB"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#FF6B35"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="#4CAF50"/>
    <SolidColorBrush x:Key="GoldBrush"           Color="#FFD700"/>

    <!-- Input controls -->
    <SolidColorBrush x:Key="InputBackground"     Color="#333333"/>
    <SolidColorBrush x:Key="InputBorder"         Color="#555555"/>
    <SolidColorBrush x:Key="InputText"           Color="White"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonPrimaryBg"     Color="#00D4FF"/>
    <SolidColorBrush x:Key="ButtonPrimaryFg"     Color="Black"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg"   Color="#444444"/>
    <SolidColorBrush x:Key="ButtonSecondaryFg"   Color="White"/>
    <SolidColorBrush x:Key="ButtonDangerBg"      Color="#D32F2F"/>
    <SolidColorBrush x:Key="ButtonDangerFg"      Color="White"/>

    <!-- Scrollbar / borders -->
    <SolidColorBrush x:Key="BorderBrush"         Color="#444444"/>
    <SolidColorBrush x:Key="SeparatorBrush"      Color="#3A3A3A"/>

    <!-- Required brushes for new windows -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#444444"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="White"/>


</ResourceDictionary>
