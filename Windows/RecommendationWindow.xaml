<Window x:Class="CleanAimTracker.Windows.RecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Recommendation"
        Width="900"
        Height="650"
        MinWidth="800"
        MinHeight="550"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Icon="{StaticResource AppLogo}"
        x:Name="RootWindow">

    <Border Background="{DynamicResource AppBackground}"
            CornerRadius="8"
            BorderBrush="#33000000"
            BorderThickness="1">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  Background="#22252A"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        Margin="10,0,6,0"
                        VerticalAlignment="Center"
                        CornerRadius="3"
                        Background="#00AFFF">
                    <TextBlock Text="CA"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="13"
                           Text="Sensitivity Recommendation" />

                <Button Grid.Column="2"
                        Width="32"
                        Height="24"
                        Margin="0,0,4,0"
                        Click="Minimize_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <TextBlock Text="–"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"/>
                </Button>

                <Button Grid.Column="3"
                        Width="32"
                        Height="24"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <TextBlock Text="✕"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="12"/>
                </Button>
            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="16,10,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Recommended Settings"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Game:"
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,6,0"/>

                        <ComboBox x:Name="GameCombo"
                                  Width="200"
                                  ItemsSource="{Binding GameOptions, ElementName=RootWindow}"
                                  DisplayMemberPath="GameName"
                                  Background="{DynamicResource CardBackground}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  BorderBrush="#444"
                                  Padding="4,2"
                                  SelectionChanged="GameCombo_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- MAIN AREA -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">

                            <!-- HERO CARD: Recommended Sensitivity -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource CardBgCyan}"
                                    BorderBrush="#00D4FF" BorderThickness="0,2,0,0"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="RECOMMENDED SENSITIVITY"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4}}"
                                               FontSize="40" FontWeight="Black"
                                               Foreground="#00D4FF"
                                               Margin="0,4,0,6"/>
                                    <TextBlock Text="{Binding RecommendedSensitivityRange}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding SensVerdict}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="11" FontStyle="Italic"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- DPI + cm/360 row -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- DPI -->
                                <Border Grid.Column="0"
                                        Style="{StaticResource MetricCardStyle}"
                                        Background="{StaticResource CardBgCyan}"
                                        BorderBrush="#00D4FF" BorderThickness="0,2,0,0">
                                    <StackPanel>
                                        <TextBlock Text="DPI" Style="{StaticResource MetricLabelStyle}"/>
                                        <TextBlock Text="{Binding RecommendedDPI}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="#00D4FF"/>
                                    </StackPanel>
                                </Border>

                                <!-- YOUR SENSITIVITY (cm/360) -->
                                <Border Grid.Column="2"
                                        Style="{StaticResource MetricCardStyle}"
                                        Background="{StaticResource CardBgCyan}"
                                        BorderBrush="#00D4FF" BorderThickness="0,2,0,0">
                                    <StackPanel>
                                        <TextBlock Text="YOUR SENSITIVITY" Style="{StaticResource MetricLabelStyle}"/>
                                        <TextBlock Text="{Binding RecommendedSensitivity, StringFormat={}{0:F4}}"
                                                   Style="{StaticResource MetricValueStyle}"
                                                   Foreground="#00D4FF"/>
                                        <TextBlock Text="{Binding RecommendedCm360, StringFormat={}{0:F1} cm/360}"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Confidence with visual bar -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Background="{StaticResource CardBgCyan}"
                                    BorderBrush="#00D4FF" BorderThickness="0,2,0,0"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="CONFIDENCE" Style="{StaticResource MetricLabelStyle}"/>
                                        <TextBlock Text="{Binding Confidence, StringFormat={}{0}%}"
                                                   Foreground="#00D4FF"
                                                   FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <!-- 6px progress bar — ScaleTransform scales fill from left -->
                                    <Border Height="6" CornerRadius="3"
                                            Background="#131B24">
                                        <Border Height="6" CornerRadius="3"
                                                Background="#00D4FF"
                                                RenderTransformOrigin="0,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding ConfidenceRatio, ElementName=RootWindow}"/>
                                            </Border.RenderTransform>
                                        </Border>
                                    </Border>
                                    <TextBlock Text="{Binding Confidence, StringFormat={}Based on {0}% data confidence}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="11" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Explanation -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="ANALYSIS"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding Explanation}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="12" Margin="0,4,0,8"/>
                                    <TextBlock Text="TIPS"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <ItemsControl ItemsSource="{Binding Tips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           FontSize="12" Margin="0,0,0,4">
                                                    <Run Text="• "/>
                                                    <Run Text="{Binding ., Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- RIGHT COLUMN (bound to window) -->
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">

                            <!-- Settings to Apply -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,12">
                                <StackPanel>

                                    <TextBlock Text="SETTINGS TO APPLY"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding GameSettingsLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- ADS / Scope -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding HasAdsScopeSection, ElementName=RootWindow, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>

                                    <TextBlock Text="ADS / SCOPE"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding AdsScopeLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- Advanced -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,12">
                                <StackPanel>

                                    <TextBlock Text="ADVANCED"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding AdvancedLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- Game Tips -->
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,12">
                                <StackPanel>

                                    <TextBlock Text="TIPS FOR THIS GAME"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding GameTipsLines, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryText}">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding ., Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">

                    <Button Content="Copy Settings"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource GlowButton}"
                            Click="CopySettings_Click"/>

                    <Button Content="Copy Comparison"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource GlowButton}"
                            Click="CopyComparison_Click"/>

                    <Button Content="Close"
                            Width="150"
                            Style="{StaticResource GlowButton}"
                            Click="Close_Click"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
