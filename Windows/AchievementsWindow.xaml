<Window x:Class="CleanAimTracker.Windows.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Achievements"
        Width="540" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                Padding="24,16"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🏆  Achievements"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"/>
                    <TextBlock x:Name="ProgressText"
                               Text="Loading..."
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Close_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource SecondaryText}"
                        FontSize="14" Cursor="Hand"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" x:Name="OverallProgressBar"
                     Minimum="0" Maximum="100" Value="0"
                     Height="4"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="{DynamicResource SeparatorBrush}"
                     BorderThickness="0"/>

        <!-- Achievement list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,0,20,16">
            <ItemsControl x:Name="AchievementGroups">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Category}"
                                       Style="{StaticResource CategoryHeaderStyle}"/>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6"
                                                CornerRadius="8"
                                                Padding="14,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Emoji -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Emoji}"
                                                           FontSize="26"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                                <!-- Name + desc -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryText}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <!-- Unlock date -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding UnlockDateDisplay}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
