<Window x:Class="CleanAimTracker.Windows.RecommendedDrillsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recommended Drills"
        Height="360"
        Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12"
                Padding="20"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="Recommended Drills"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrush}"
                           Margin="0 0 0 16"/>

                <StackPanel Margin="0 0 0 12">
                    <TextBlock Text="Suggested Settings:"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0 0 0 6"/>

                    <TextBlock x:Name="SettingsText"
                               FontSize="14"
                               Foreground="{DynamicResource ForegroundBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Recommended Drills:"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0 0 0 6"/>

                    <TextBlock x:Name="DrillListText"
                               FontSize="14"
                               Foreground="{DynamicResource ForegroundBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Content="Close"
                        HorizontalAlignment="Right"
                        Width="80"
                        Margin="0 20 0 0"
                        Padding="6"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        Click="Close_Click"/>
            </StackPanel>

        </Border>

    </Grid>
</Window>
