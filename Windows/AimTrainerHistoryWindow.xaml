<Window x:Class="CleanAimTracker.Windows.AimTrainerHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aim Trainer History"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="580" Height="640"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource AppBackground}"
            CornerRadius="14"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="14 14 0 0"
                    Padding="24 18">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Aim Trainer History"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text="Loading..."
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="12" Margin="0 4 0 0"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="28" Height="28"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Tab body -->
            <TabControl Grid.Row="1"
                        Background="{DynamicResource AppBackground}"
                        BorderThickness="0"
                        Padding="0">

                <!-- ── Tab 1: History ────────────────────────────────── -->
                <TabItem Header="History">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <ItemsControl x:Name="HistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="#1AFFFFFF"
                                            BorderThickness="1"
                                            Padding="16,14"
                                            Margin="0,0,0,10"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#3300D4FF"/>
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundAlt}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MMM dd, yyyy  •  h:mm tt}'}"
                                                           Foreground="{DynamicResource MutedText}" FontSize="11"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding Scenario}"
                                                               FontSize="15" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryText}"/>
                                                    <TextBlock Text=" · " Foreground="{DynamicResource MutedText}" FontSize="13"/>
                                                    <TextBlock Text="{Binding Difficulty}"
                                                               Foreground="{DynamicResource MutedText}" FontSize="13"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding Accuracy, StringFormat='{}{0:F0}% acc'}"
                                                               Foreground="{DynamicResource LabelText}" FontSize="12" Margin="0,0,14,0"/>
                                                    <TextBlock Text="{Binding AvgReactionMs, StringFormat='{}{0:F0}ms avg'}"
                                                               Foreground="{DynamicResource LabelText}" FontSize="12" Margin="0,0,14,0"/>
                                                    <TextBlock Text="{Binding MaxStreak, StringFormat='{}streak {0}'}"
                                                               Foreground="{DynamicResource LabelText}" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Score, StringFormat='{}{0:N0}'}"
                                                           FontSize="28" FontWeight="Black"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="pts" Foreground="{DynamicResource MutedText}"
                                                           FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <Button Content="Details"
                                                        HorizontalAlignment="Center"
                                                        Padding="10,4" FontSize="11"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource AccentBrush}"
                                                        BorderThickness="1"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        Cursor="Hand"
                                                        Tag="{Binding}"
                                                        Click="ViewDetails_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Tab 2: Personal Bests ─────────────────────────── -->
                <TabItem Header="Personal Bests">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Best result per scenario · all time"
                                       FontSize="11" Foreground="{DynamicResource MutedText}"
                                       Margin="0,0,0,14"/>
                            <ItemsControl x:Name="PersonalBestList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Background="{DynamicResource CardBackground}"
                                                Padding="16,14"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Rank badge -->
                                                <Border Grid.Column="0"
                                                        Background="{DynamicResource SeparatorBrush}"
                                                        CornerRadius="6"
                                                        Padding="8,4"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ScenarioEmoji}"
                                                               FontSize="22" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Scenario + stats -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Scenario}"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="{DynamicResource PrimaryText}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding BestAccuracy, StringFormat='{}{0:F0}% acc'}"
                                                                   FontSize="12" Foreground="{DynamicResource LabelText}"
                                                                   Margin="0,0,12,0"/>
                                                        <TextBlock Text="{Binding BestReaction, StringFormat='{}{0:F0}ms best'}"
                                                                   FontSize="12" Foreground="{DynamicResource LabelText}"
                                                                   Margin="0,0,12,0"/>
                                                        <TextBlock Text="{Binding BestStreak, StringFormat='{}streak {0}'}"
                                                                   FontSize="12" Foreground="{DynamicResource LabelText}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding AchievedOn, StringFormat='{}{0:MMM dd, yyyy}'}"
                                                               FontSize="10" Foreground="{DynamicResource MutedText}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <!-- Best score -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding BestScore, StringFormat='{}{0:N0}'}"
                                                               FontSize="26" FontWeight="Black"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="pts" FontSize="10"
                                                               Foreground="{DynamicResource MutedText}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="0 0 14 14"
                    Padding="24 14">
                <Button Content="Close"
                        Click="Close_Click"
                        Width="100" Height="36"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedText}"
                        FontSize="13"
                        BorderThickness="1"
                        BorderBrush="#333"
                        Cursor="Hand"/>
            </Border>

        </Grid>
    </Border>
</Window>
