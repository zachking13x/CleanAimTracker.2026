<Window x:Class="CleanAimTracker.FirstLaunchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanAimTracker"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0D0D0D"
        ResizeMode="NoResize">

    <Grid>
        <!-- Subtle radial glow behind center content -->
        <Ellipse Width="700" Height="700"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#1A0029" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Center content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="540">

            <!-- Logo / icon area -->
            <TextBlock Text="🎯"
                       FontSize="64"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- App name -->
            <TextBlock Text="Clean Aim Tracker"
                       FontSize="42"
                       FontWeight="Black"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <!-- Tagline -->
            <TextBlock Text="Real-time mouse analytics for FPS players."
                       FontSize="17"
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,48"
                       TextAlignment="Center"/>

            <!-- Instruction card -->
            <Border Background="#1A1A1A"
                    CornerRadius="14"
                    Padding="32,24"
                    Margin="0,0,0,40"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="HOW IT WORKS"
                               Foreground="#555555"
                               FontSize="11"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="①" Foreground="#7B2FFF" FontSize="18" FontWeight="Bold" Margin="0,0,12,0"/>
                        <TextBlock Text="Click Hit Start below" Foreground="#CCCCCC" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="②" Foreground="#7B2FFF" FontSize="18" FontWeight="Bold" Margin="0,0,12,0"/>
                        <TextBlock Text="Move your mouse naturally for 90 seconds" Foreground="#CCCCCC" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="③" Foreground="#7B2FFF" FontSize="18" FontWeight="Bold" Margin="0,0,12,0"/>
                        <TextBlock Text="Get your personalized aim analysis" Foreground="#CCCCCC" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Hit Start button -->
            <Button x:Name="HitStartBtn"
                    Content="▶  Hit Start"
                    Click="HitStart_Click"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="Black"
                    Background="#7B2FFF"
                    BorderThickness="0"
                    Padding="0,18"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    Height="60">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#7B2FFF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#9B4FFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Skip link -->
            <TextBlock Text="Skip — I'll set up manually"
                       Foreground="#444444"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Cursor="Hand"
                       MouseDown="Skip_Click"
                       TextDecorations="Underline"/>

        </StackPanel>
    </Grid>
</Window>
