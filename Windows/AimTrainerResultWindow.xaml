<Window x:Class="CleanAimTracker.Windows.AimTrainerResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drill Results"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="680" Height="720"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource AppBackground}"
            CornerRadius="14"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="14 14 0 0"
                    Padding="24 18">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="HeadlineText"
                                   Text="Drill Complete"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryText}"
                                   TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0 6 0 0">
                            <Border x:Name="RatingBadge"
                                    Background="#1A00D4FF"
                                    CornerRadius="4"
                                    Padding="8 3"
                                    Margin="0 0 10 0">
                                <TextBlock x:Name="RatingText"
                                           Text="--"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="12" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="ScenarioBadgeText"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Score -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="SCORE"
                                   Foreground="{DynamicResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ScoreText"
                                   Text="0"
                                   FontSize="36" FontWeight="Black"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ BODY ═══ -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24 16">
                <StackPanel>

                    <!-- STATS ROW -->
                    <Grid Margin="0 0 0 20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource CardBackground}"
                                CornerRadius="8" Padding="12 10" Margin="0 0 8 0">
                            <StackPanel>
                                <TextBlock Text="ACCURACY" Foreground="{DynamicResource MutedText}"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AccuracyText" Text="--"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"
                                           Margin="0 4 0 0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource CardBackground}"
                                CornerRadius="8" Padding="12 10" Margin="0 0 8 0">
                            <StackPanel>
                                <TextBlock Text="AVG REACTION" Foreground="{DynamicResource MutedText}"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AvgReactionText" Text="--"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"
                                           Margin="0 4 0 0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource CardBackground}"
                                CornerRadius="8" Padding="12 10" Margin="0 0 8 0">
                            <StackPanel>
                                <TextBlock Text="BEST REACTION" Foreground="{DynamicResource MutedText}"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock x:Name="BestReactionText" Text="--"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="LightGreen"
                                           Margin="0 4 0 0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="{DynamicResource CardBackground}"
                                CornerRadius="8" Padding="12 10">
                            <StackPanel>
                                <TextBlock Text="BEST STREAK" Foreground="{DynamicResource MutedText}"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock x:Name="StreakText" Text="--"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="Gold"
                                           Margin="0 4 0 0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Hits / Misses bar -->
                    <Border Background="{DynamicResource CardBackground}"
                            CornerRadius="8" Padding="16 12" Margin="0 0 0 20">
                        <StackPanel>
                            <Grid Margin="0 0 0 8">
                                <TextBlock Text="HITS vs MISSES"
                                           Foreground="{DynamicResource MutedText}"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock x:Name="HitsText" Foreground="LightGreen"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text=" hits  " Foreground="{DynamicResource MutedText}" FontSize="12"/>
                                    <TextBlock x:Name="MissesText" Foreground="OrangeRed"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text=" misses" Foreground="{DynamicResource MutedText}" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#1AFFFFFF" CornerRadius="4" Height="8">
                                <Border x:Name="AccuracyBar"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="4" Height="8"
                                        HorizontalAlignment="Left"
                                        Width="0"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ TASK-16: Personal Best badges ═══ -->
                    <WrapPanel x:Name="PBBadgesPanel"
                               Margin="0,0,0,12"
                               Visibility="Collapsed"/>

                    <!-- ═══ PB CELEBRATION BANNER — gold, delayed fade-in ═══ -->
                    <Border x:Name="PBBanner"
                            Background="#1AF5C842"
                            BorderBrush="{StaticResource AccentGold}"
                            BorderThickness="0 0 0 2"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,0,0,16"
                            Opacity="0"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏆" FontSize="22"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="PBBannerTitle"
                                           Text="NEW PERSONAL BEST!"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGold}"/>
                                <TextBlock x:Name="PBBannerDetail"
                                           Text=""
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ XP PANEL ═══ -->
                    <Border x:Name="XpPanel"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⚡ " FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="XpEarnedText"
                                               Text="+0 XP"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGold}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="XpLevelText"
                                           Text="LEVEL 1"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedText}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <!-- XP progress bar -->
                            <Border Background="{DynamicResource BgElevated}"
                                    CornerRadius="4" Height="6">
                                <Border x:Name="XpProgressBar"
                                        Background="{StaticResource AccentGold}"
                                        CornerRadius="4" Height="6"
                                        HorizontalAlignment="Left"
                                        Width="0"/>
                            </Border>
                            <!-- Level-up banner — revealed on level-up -->
                            <Border x:Name="LevelUpBanner"
                                    Margin="0,10,0,0"
                                    Background="#1AF5C842"
                                    BorderBrush="{StaticResource AccentGold}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="6"
                                    Padding="10,9"
                                    Opacity="0"
                                    Visibility="Collapsed"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Border.RenderTransform>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⬆  " FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGold}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LevelUpText"
                                               Text="LEVEL UP!"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGold}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ NEAR-MISS ACHIEVEMENT HINT ═══ -->
                    <Border x:Name="NearMissPanel"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="#22F5C842"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,14"
                            Visibility="Collapsed"
                            Opacity="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="NearMissText"
                                       Text=""
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══ TASK-17: Top 5 Sessions ═══ -->
                    <Border x:Name="Top5Panel"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="8" Padding="16,12"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="Top5HeaderText"
                                       Text="TOP 5 — SCENARIO"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <ItemsControl x:Name="Top5List">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding RankDisplay}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DateDisplay}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource LabelText}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AccuracyDisplay}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource LabelText}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding ReactionDisplay}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource LabelText}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding ScoreDisplay}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ═══ AI COACHING SECTION ═══ -->
                    <Border x:Name="CoachingPanel"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="10"
                            BorderBrush="#1A00D4FF"
                            BorderThickness="1"
                            Padding="20"
                            Margin="0 0 0 16">
                        <StackPanel>

                            <!-- Loading state -->
                            <StackPanel x:Name="CoachingLoading" Visibility="Visible">
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                    <TextBlock Text="🤖  " FontSize="16"/>
                                    <TextBlock Text="AI COACH" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Analyzing your drill..."
                                           Foreground="{DynamicResource MutedText}"
                                           FontSize="13" FontStyle="Italic"/>
                            </StackPanel>

                            <!-- Loaded state -->
                            <StackPanel x:Name="CoachingContent" Visibility="Collapsed">

                                <StackPanel Orientation="Horizontal" Margin="0 0 0 14">
                                    <TextBlock Text="🤖  " FontSize="16"/>
                                    <TextBlock Text="AI COACH" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Strengths -->
                                <TextBlock Text="✅  STRENGTHS"
                                           Foreground="LightGreen"
                                           FontSize="11" FontWeight="Bold"
                                           Margin="0 0 0 6"/>
                                <ItemsControl x:Name="StrengthsList" Margin="0 0 0 14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontSize="13" TextWrapping="Wrap"
                                                       Margin="0 0 0 6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Weaknesses -->
                                <TextBlock Text="⚠️  AREAS TO IMPROVE"
                                           Foreground="#FFAA44"
                                           FontSize="11" FontWeight="Bold"
                                           Margin="0 0 0 6"/>
                                <ItemsControl x:Name="WeaknessesList" Margin="0 0 0 14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontSize="13" TextWrapping="Wrap"
                                                       Margin="0 0 0 6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Advice -->
                                <TextBlock Text="💡  COACHING TIPS"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="11" FontWeight="Bold"
                                           Margin="0 0 0 6"/>
                                <ItemsControl x:Name="AdviceList" Margin="0 0 0 14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A00D4FF" CornerRadius="6"
                                                    Padding="10 8" Margin="0 0 0 6">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Next drill -->
                                <Border Background="#0A4CAF50" CornerRadius="6" Padding="12 10" Margin="0 0 0 12">
                                    <StackPanel>
                                        <TextBlock Text="NEXT DRILL SUGGESTION"
                                                   Foreground="LightGreen"
                                                   FontSize="10" FontWeight="Bold"
                                                   Margin="0 0 0 4"/>
                                        <TextBlock x:Name="NextDrillText"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   FontSize="13" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="NextDrillReasonText"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                        <TextBlock x:Name="NextDrillFocusCueText"
                                                   FontSize="11"
                                                   Foreground="#00D4FF"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,8"/>
                                        <Button x:Name="StartPrescribedDrillBtn"
                                                Content="▶  Start This Drill"
                                                Visibility="Collapsed"
                                                Click="StartPrescribedDrill_Click"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="Black"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Padding="12,7"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <!-- Motivational close -->
                                <TextBlock x:Name="MotivationalText"
                                           Foreground="{DynamicResource MutedText}"
                                           FontSize="12" FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Error state -->
                            <TextBlock x:Name="CoachingError"
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="12" TextWrapping="Wrap"
                                       Text="AI coaching unavailable. Check your settings if the problem persists."/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ FOOTER BUTTONS ═══ -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="0 0 14 14"
                    Padding="24 16">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="PlayAgainBtn"
                                Content="▶  Play Again"
                                Click="PlayAgain_Click"
                                Width="140" Height="38"
                                Margin="0,0,10,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="Black"
                                FontWeight="Bold"
                                FontSize="13"
                                BorderThickness="0"
                                Cursor="Hand"/>
                        <Button x:Name="ShareBtn"
                                Content="📤  Share Result"
                                Click="ShareResult_Click"
                                Height="38"
                                Padding="12,0"
                                Background="{DynamicResource CardBackgroundAlt}"
                                Foreground="{DynamicResource PrimaryText}"
                                FontSize="12"
                                BorderThickness="1"
                                BorderBrush="#444"
                                Cursor="Hand"
                                Visibility="Collapsed"/>
                    </StackPanel>

                    <Button Content="Close"
                            Click="Close_Click"
                            Width="100" Height="38"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            FontSize="13"
                            BorderThickness="1"
                            BorderBrush="#333"
                            Cursor="Hand"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
