<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         CLEAN AIM TRACKER — DARK THEME v2
         Deeper blacks, better contrast, consistent radii
    ═══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground"       Color="#141414"/>
    <SolidColorBrush x:Key="CardBackground"       Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardBackgroundAlt"    Color="#252525"/>
    <SolidColorBrush x:Key="BannerBackground"     Color="#0D2233"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryText"          Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SecondaryText"        Color="#B0B0B0"/>
    <SolidColorBrush x:Key="MutedText"            Color="#666666"/>
    <SolidColorBrush x:Key="LabelText"            Color="#999999"/>

    <!-- Accent — clean cyan -->
    <SolidColorBrush x:Key="AccentBrush"          Color="#00D4FF"/>
    <SolidColorBrush x:Key="AccentDark"           Color="#0099BB"/>
    <SolidColorBrush x:Key="AccentSubtle"         Color="#0A1A22"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="#FF6B35"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="#4CAF50"/>
    <SolidColorBrush x:Key="GoldBrush"            Color="#FFD700"/>
    <SolidColorBrush x:Key="DangerBrush"          Color="#EF5350"/>

    <!-- Input controls -->
    <SolidColorBrush x:Key="InputBackground"      Color="#252525"/>
    <SolidColorBrush x:Key="InputBorder"          Color="#3A3A3A"/>
    <SolidColorBrush x:Key="InputText"            Color="#F0F0F0"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonPrimaryBg"      Color="#00D4FF"/>
    <SolidColorBrush x:Key="ButtonPrimaryFg"      Color="#000000"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg"    Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ButtonSecondaryFg"    Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ButtonDangerBg"       Color="#C62828"/>
    <SolidColorBrush x:Key="ButtonDangerFg"       Color="#FFFFFF"/>

    <!-- Borders / separators -->
    <SolidColorBrush x:Key="BorderBrush"          Color="#2E2E2E"/>
    <SolidColorBrush x:Key="SeparatorBrush"       Color="#242424"/>
    <SolidColorBrush x:Key="CardBorderBrush"      Color="#2E2E2E"/>

    <!-- Legacy aliases (keep for compatibility) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#141414"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"   Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ForegroundBrush"       Color="#F0F0F0"/>

    <!-- ── GLOBAL BUTTON STYLE ─────────────────────────────────── -->
    <Style TargetType="Button">
        <Setter Property="Background"       Value="{DynamicResource ButtonSecondaryBg}"/>
        <Setter Property="Foreground"       Value="{DynamicResource ButtonSecondaryFg}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── GLOBAL TEXTBOX STYLE ───────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background"      Value="{DynamicResource InputBackground}"/>
        <Setter Property="Foreground"      Value="{DynamicResource InputText}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8 4"/>
        <Setter Property="CaretBrush"      Value="{DynamicResource AccentBrush}"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource AccentBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── SCROLLBAR STYLE ────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
    </Style>

    <!-- ── COMBOBOX ITEM ──────────────────────────────────────── -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground"  Value="{DynamicResource PrimaryText}"/>
        <Setter Property="Background"  Value="{DynamicResource CardBackground}"/>
        <Setter Property="Padding"     Value="8 5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2A3A42"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── COMBOBOX ───────────────────────────────────────────── -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"      Value="{DynamicResource InputBackground}"/>
        <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8 4"/>
    </Style>

    <!-- ── LISTBOX ────────────────────────────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
    </Style>
    <Style TargetType="ListBoxItem">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="Foreground"  Value="{DynamicResource PrimaryText}"/>
        <Setter Property="Padding"     Value="0"/>
        <Setter Property="Margin"      Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── SCROLLVIEWER ───────────────────────────────────────── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
