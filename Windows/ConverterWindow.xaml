<Window x:Class="CleanAimTracker.Windows.ConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensitivity Converter"
        Height="520"
        Width="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LabelText}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0 0 0 12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6 4"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Sensitivity Converter"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryText}"
                   Margin="0 0 0 16"/>

        <!-- Two-panel input -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SOURCE panel -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="FROM" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0 0 0 10"/>

                    <TextBlock Text="Game:" Style="{StaticResource SectionLabel}"/>
                    <ComboBox x:Name="SourceGameCombo" SelectionChanged="OnInputChanged"/>

                    <TextBlock Text="DPI:" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="DpiInput" TextChanged="OnInputChanged"/>

                    <TextBlock Text="In-game Sensitivity:" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="SensInput" TextChanged="OnInputChanged"/>

                    <TextBlock Text="cm/360:" Style="{StaticResource SectionLabel}"/>
                    <TextBlock x:Name="SourceCm360Text"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="16" FontWeight="SemiBold"
                               Text="--"/>
                </StackPanel>
            </Border>

            <!-- Arrow -->
            <TextBlock Grid.Column="1"
                       Text="→"
                       FontSize="28"
                       Foreground="{DynamicResource AccentBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <!-- TARGET panel -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="TO" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0 0 0 10"/>

                    <TextBlock Text="Game:" Style="{StaticResource SectionLabel}"/>
                    <ComboBox x:Name="TargetGameCombo" SelectionChanged="OnInputChanged"/>

                    <TextBlock Text="Recommended DPI:" Style="{StaticResource SectionLabel}"/>
                    <TextBlock x:Name="TargetDpiText"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Text="--"
                               Margin="0 0 0 10"/>

                    <TextBlock Text="Converted Sensitivity:" Style="{StaticResource SectionLabel}"/>
                    <TextBlock x:Name="ResultSensText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="26"
                               FontWeight="Bold"
                               Text="--"/>

                    <TextBlock Text="Same cm/360:" Style="{StaticResource SectionLabel}" Margin="0 8 0 4"/>
                    <TextBlock x:Name="TargetCm360Text"
                               Foreground="{DynamicResource PrimaryText}"
                               FontSize="14"
                               Text="--"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status / error message -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Foreground="#FF6B6B"
                   FontSize="12"
                   Margin="0 0 0 10"
                   Text=""/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CopyButton"
                    Content="📋 Copy Sensitivity"
                    Width="160"
                    Height="34"
                    Margin="0 0 10 0"
                    Click="CopyResult_Click"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"/>
            <Button Content="Close"
                    Width="80"
                    Height="34"
                    Click="Close_Click"
                    Background="{DynamicResource CardBackground}"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AccentBrush}"/>
        </StackPanel>
    </Grid>
</Window>
