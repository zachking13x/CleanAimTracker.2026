<Window x:Class="CleanAimTracker.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="460"
        Height="480"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        Icon="{StaticResource AppLogo}"
        UseLayoutRounding="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                Padding="24 18"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0 0 0 1">
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}"/>
                <TextBlock Text="Customize your Clean Aim Tracker experience"
                           FontSize="12"
                           Foreground="{DynamicResource MutedText}"
                           Margin="0 4 0 0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24 20">
            <StackPanel>

                <!-- Mouse Settings -->
                <TextBlock Text="MOUSE SETTINGS"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="10" FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Mouse DPI"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Your hardware DPI setting"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11" Margin="0 2 0 0"/>
                        </StackPanel>
                        <TextBox x:Name="DpiInput"
                                 Grid.Column="1"
                                 Height="34"
                                 FontSize="14"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource InputText}"
                                 BorderBrush="{DynamicResource InputBorder}"
                                 BorderThickness="1"/>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="In-Game Sensitivity"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Default sensitivity value"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11" Margin="0 2 0 0"/>
                        </StackPanel>
                        <TextBox x:Name="SensitivityInput"
                                 Grid.Column="1"
                                 Height="34"
                                 FontSize="14"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource InputText}"
                                 BorderBrush="{DynamicResource InputBorder}"
                                 BorderThickness="1"/>
                    </Grid>
                </Border>

                <!-- Appearance -->
                <TextBlock Text="APPEARANCE"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="10" FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="10" Padding="18" Margin="0 0 0 20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Theme"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Light or dark interface"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11" Margin="0 2 0 0"/>
                        </StackPanel>
                        <ComboBox x:Name="ThemeSelector"
                                  Grid.Column="1"
                                  Height="34"
                                  FontSize="13">
                            <ComboBoxItem Content="Dark"/>
                            <ComboBoxItem Content="Light"/>
                        </ComboBox>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackground}"
                Padding="24 16"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0 1 0 0">
            <Grid>
                <Button Content="Cancel"
                        Click="Cancel_Click"
                        HorizontalAlignment="Left"
                        Width="90" Height="36"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedText}"
                        FontSize="13"
                        BorderThickness="1"
                        BorderBrush="#444"
                        Cursor="Hand"/>
                <Button Content="Save Settings"
                        Click="SaveButton_Click"
                        HorizontalAlignment="Right"
                        Width="140" Height="36"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="Black"
                        FontSize="13"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
